mixin indicator(opts)
  - opts = opts || {}
  - const cls = ['dp-indicator', 'indicator', opts.class].filter(Boolean).join(' ')
  div(class=cls)&attributes(attributes)
    block

mixin indicator-item(opts)
  - opts = opts || {}
  - const cls = ['dp-indicator-item', 'indicator-item', opts.horizontal && `indicator-${opts.horizontal}`, opts.vertical && `indicator-${opts.vertical}`, opts.class].filter(Boolean).join(' ')
  span(class=cls)&attributes(attributes)
    if opts.text
      | #{opts.text}
    block
