mixin dp-datatable(opts)
  - opts = opts || {}
  - const headers = opts.headers || []
  - const rows = opts.rows || []
  - const pagination = opts.pagination
  div.dp-datatable&attributes(attributes)
    div.dp-datatable-scroll
      +table({zebra: opts.zebra, size: opts.size, pinRows: true, pinCols: opts.pinCols, autoWidth: opts.autoWidth, class: opts.class})
        if headers.length
          thead
            tr
              each h in headers
                th= h
        tbody
          each row in rows
            tr
              each cell in row
                td= cell
    div.dp-datatable-pagination
      if pagination
        - const total = pagination.total || 1
        - const current = pagination.current || 1
        - for (let i = 1; i <= total; i++)
          button(class=`dp-datatable-page${i === current ? ' active' : ''}`)= i
