//- DUI-evolved form system: +dp-form, +dp-fitem, +dp-group, +dp-hgroup

//- Form container with optional column layout and form-part detection
mixin dp-form(opts)
  - opts = opts || {}
  - if (typeof _dpFormIds === 'undefined') _dpFormIds = {}
  - const formId = opts.id || attributes.id
  - const isFormPart = formId && _dpFormIds[formId]
  - if (formId) _dpFormIds[formId] = true
  - const cls = ['dp-form', opts.class].filter(Boolean).join(' ')
  - const formStyle = opts.labelWidth ? `--label-w:${opts.labelWidth}` : opts.style
  if isFormPart
    //- Duplicate ID detected: render as form-part
    form(class=cls data-form-part=formId style=formStyle)&attributes({...attributes, id: undefined})
      block
  else
    form(class=cls id=formId style=formStyle)&attributes(attributes)
      block

//- Form item: label + auto-detected input
//- Usage: +dp-fitem('Label', {class:'combobox', name:'FIELD', id:'~'})
mixin dp-fitem(label, input, fitemOpts)
  - input = input || {}
  - fitemOpts = fitemOpts || {}
  - const inputClass = input.class || ''
  - const widgetType = inputClass.split(' ')[0] || 'textbox'
  - const autoId = input.id === '~' ? input.name : input.id
  - const isMultiline = widgetType === 'multiline' || widgetType === 'textarea' || input.multiline
  - const isCheckbox = widgetType === 'checkbox'
  - const isRadio = widgetType === 'radio'
  - const isToggle = widgetType === 'toggle'
  - const hasPre = input.pre
  - const hasPost = input.post
  - const hasSlots = hasPre || hasPost
  - const fitemCls = ['dp-fitem', 'mb-2', isMultiline && 'dp-fitem-multiline', fitemOpts.class].filter(Boolean).join(' ')
  div(class=fitemCls)
    //- Label
    if isCheckbox || isRadio || isToggle
      label.dp-fitem-label.fieldset-label.flex.items-center.gap-2.cursor-pointer(for=autoId)
        +dp-fitem-input(input, widgetType, autoId)
        | #{label}
        if input.required
          span.text-error *
    else
      label.dp-fitem-label.fieldset-label(for=autoId class=isMultiline ? 'self-start mt-1' : '')
        | #{label}
        if input.required
          span.text-error *
      if hasSlots
        //- Join group: [pre] [input] [post]
        div.dp-fitem-slots.join.w-full
          if hasPre
            if typeof input.pre === 'string'
              span.dp-fitem-pre.join-item.flex.items-center.px-2.bg-base-200.border.border-base-300
                +dp-icon(input.pre, {size: 'sm'})
            else
              span.dp-fitem-pre.join-item.flex.items-center.px-2.bg-base-200.border.border-base-300
                | #{input.pre.text || ''}
          +dp-fitem-input(input, widgetType, autoId, hasSlots)
          if hasPost
            if typeof input.post === 'string'
              span.dp-fitem-post.join-item.flex.items-center.px-2.bg-base-200.border.border-base-300.cursor-pointer
                +dp-icon(input.post, {size: 'sm'})
            else if input.post.action
              button.dp-fitem-post.join-item.btn(type="button" id=input.post.id)
                if input.post.icon
                  +dp-icon(input.post.icon, {size: 'sm'})
                if input.post.text
                  | #{input.post.text}
            else
              span.dp-fitem-post.join-item.flex.items-center.px-2.bg-base-200.border.border-base-300
                | #{input.post.text || ''}
      else
        +dp-fitem-input(input, widgetType, autoId)
      block

//- Internal: render the correct input element based on widget type
mixin dp-fitem-input(input, widgetType, autoId, inSlot)
  - const color = input.color || 'primary'
  - const size = input.size
  - const ji = inSlot ? 'join-item' : ''
  if widgetType === 'combobox' || widgetType === 'qbe'
    - const cls = ['dp-combobox', 'w-full', ji, input.class].filter(Boolean).join(' ')
    div(class=cls id=autoId)&attributes(input.attrs || {})
      input.dp-cb-display.input(type="text" class=[`input-${color}`, size && `input-${size}`, 'w-full', ji].filter(Boolean).join(' ') placeholder=input.placeholder readonly=input.editable ? undefined : true)
      input(type="hidden" name=input.name required=input.required value=input.value)
      button.dp-cb-toggle(type="button" tabindex="-1")
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
      ul.dp-cb-dropdown.menu
        if input.options
          each opt in input.options
            if typeof opt === 'string'
              li(data-value=opt)
                a= opt
            else
              li(data-value=opt.value)
                a= opt.text || opt.value
  else if widgetType === 'multiline' || widgetType === 'textarea'
    - const cls = ['dp-textarea', 'textarea', `textarea-${color}`, size && `textarea-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    textarea(class=cls name=input.name id=autoId rows=input.rows || 3 placeholder=input.placeholder required=input.required readonly=input.readonly)&attributes(input.attrs || {})
      if input.value
        | #{input.value}
  else if widgetType === 'checkbox'
    - const cls = ['dp-checkbox', 'checkbox', `checkbox-${color}`, size && `checkbox-${size}`, ji, input.class].filter(Boolean).join(' ')
    input(type="checkbox" class=cls name=input.name id=autoId checked=input.checked || input.value required=input.required)&attributes(input.attrs || {})
  else if widgetType === 'radio'
    - const cls = ['dp-radio', 'radio', `radio-${color}`, size && `radio-${size}`, ji, input.class].filter(Boolean).join(' ')
    input(type="radio" class=cls name=input.name id=autoId value=input.value checked=input.checked required=input.required)&attributes(input.attrs || {})
  else if widgetType === 'numberbox'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="number" class=cls name=input.name id=autoId value=input.value placeholder=input.placeholder required=input.required readonly=input.readonly min=input.min max=input.max step=input.precision !== undefined ? Math.pow(10, -input.precision) : undefined)&attributes(input.attrs || {})
  else if widgetType === 'numberspinner'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="number" class=cls name=input.name id=autoId value=input.value placeholder=input.placeholder required=input.required readonly=input.readonly min=input.min max=input.max step=input.precision !== undefined ? Math.pow(10, -input.precision) : 1)&attributes(input.attrs || {})
  else if widgetType === 'datebox'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="date" class=cls name=input.name id=autoId value=input.value required=input.required readonly=input.readonly)&attributes(input.attrs || {})
  else if widgetType === 'datetimebox'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="datetime-local" class=cls name=input.name id=autoId value=input.value required=input.required readonly=input.readonly)&attributes(input.attrs || {})
  else if widgetType === 'timespinner'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="time" class=cls name=input.name id=autoId value=input.value required=input.required readonly=input.readonly)&attributes(input.attrs || {})
  else if widgetType === 'filebox'
    - const cls = ['dp-file-input', 'file-input', `file-input-${color}`, size && `file-input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="file" class=cls name=input.name id=autoId accept=input.accept required=input.required)&attributes(input.attrs || {})
  else if widgetType === 'searchbox'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="search" class=cls name=input.name id=autoId value=input.value placeholder=input.placeholder || 'Search...' required=input.required)&attributes(input.attrs || {})
  else if widgetType === 'passwordbox'
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="password" class=cls name=input.name id=autoId placeholder=input.placeholder required=input.required)&attributes(input.attrs || {})
  else if widgetType === 'toggle'
    - const cls = ['dp-toggle', 'toggle', `toggle-${color}`, size && `toggle-${size}`, ji, input.class].filter(Boolean).join(' ')
    input(type="checkbox" class=cls name=input.name id=autoId checked=input.checked || input.value required=input.required)&attributes(input.attrs || {})
  else
    //- Default: textbox
    - const cls = ['dp-input', 'input', `input-${color}`, size && `input-${size}`, 'w-full', ji, input.class].filter(Boolean).join(' ')
    input(type="text" class=cls name=input.name id=autoId value=input.value placeholder=input.placeholder required=input.required readonly=input.readonly)&attributes(input.attrs || {})

//- Vertical group — section heading + indented fields
mixin dp-group(title)
  div.dp-group.mt-3
    if title
      div.dp-group-title.text-xs.font-bold.uppercase.opacity-50.text-primary.mb-1= title
    div.dp-group-body
      block

//- Alias
mixin dp-vgroup(title)
  +dp-group(title)
    block

//- Horizontal group — heading + fields side by side
mixin dp-hgroup(title)
  div.dp-hgroup.mt-3
    if title
      div.dp-hgroup-title.text-xs.font-bold.uppercase.opacity-50.text-primary.mb-1= title
    div.dp-hgroup-body.flex.gap-4
      block
