mixin stats(opts)
  - opts = opts || {}
  - const cls = ['dp-stats', 'stats', opts.direction && `stats-${opts.direction}`, opts.class].filter(Boolean).join(' ')
  div(class=cls)&attributes(attributes)
    block

mixin stat(opts)
  - opts = opts || {}
  - const cls = ['dp-stat', 'stat', opts.class].filter(Boolean).join(' ')
  div(class=cls)&attributes(attributes)
    block

