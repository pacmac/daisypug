mixin stat-title(opts)
  - opts = opts || {}
  - const cls = ['dp-stat-title', 'stat-title', opts.class].filter(Boolean).join(' ')
  div(class=cls)&attributes(attributes)
    if opts.text
      | #{opts.text}
    block

