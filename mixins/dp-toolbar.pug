//- DUI-evolved toolbar: title + inputs + buttons with asdpx shorthand

mixin dp-toolbar(opts)
  - opts = opts || {}
  - const id = opts.id || attributes.id || ''
  - const asdpx = opts.asdpx || attributes.asdpx || ''
  - const title = opts.title || attributes.title || ''
  - const icon = opts.icon || attributes.icon || ''
  - const size = opts.size || attributes.size || 'md'
  - const btnSize = size === 'sm' ? 'xs' : size === 'lg' ? 'md' : 'sm'
  - const pad = size === 'lg' ? 'py-1.5' : 'py-1'
  - const cls = ['dp-toolbar', 'flex', 'items-center', 'gap-1', 'px-2', pad, 'bg-base-200', 'border-b', 'border-base-300', opts.class].filter(Boolean).join(' ')
  - const tbId = id ? id + '_toolbar' : undefined
  - const cleanAttrs = Object.assign({}, attributes); delete cleanAttrs.id; delete cleanAttrs.asdpx; delete cleanAttrs.title; delete cleanAttrs.icon; delete cleanAttrs.size;
  div(class=cls id=tbId)&attributes(cleanAttrs)

    //- Title section (shrink-0)
    if title
      div(class="flex items-center gap-1.5 shrink-0 mr-2")
        if icon
          +dp-icon(icon, {size: 'sm'})
        span.font-semibold.text-sm= title

    //- Inputs section (flex-1) — filled by page or JSON config
    div.flex-1.flex.items-center.gap-2.dp-toolbar-inputs

    //- Buttons section (shrink-0)
    div.flex.items-center.gap-1.shrink-0.dp-toolbar-buttons

      //- ASDPX CRUD buttons
      if asdpx.includes('a')
        +btn({size: btnSize, style: 'ghost'})(id=id ? id + '_add' : 'tb_add')
          +dp-icon('plus', {size: 'sm'})
          |  Add
      if asdpx.includes('s')
        +btn({size: btnSize, style: 'ghost', disabled: true})(id=id ? id + '_save' : 'tb_save')
          +dp-icon('save', {size: 'sm'})
          |  Save
      if asdpx.includes('e')
        +btn({size: btnSize, style: 'ghost', disabled: true})(id=id ? id + '_edit' : 'tb_edit')
          +dp-icon('square-pen', {size: 'sm'})
          |  Edit
      if asdpx.includes('d')
        +btn({size: btnSize, style: 'ghost', disabled: true})(id=id ? id + '_del' : 'tb_del')
          +dp-icon('trash-2', {size: 'sm'})
          |  Delete
      if asdpx.includes('p')
        +btn({size: btnSize, style: 'ghost'})(id=id ? id + '_print' : 'tb_print')
          +dp-icon('printer', {size: 'sm'})
          |  Print
      if asdpx.includes('x')
        +btn({size: btnSize, style: 'ghost', disabled: true})(id=id ? id + '_cancel' : 'tb_cancel')
          +dp-icon('x', {size: 'sm'})
          |  Cancel

      //- Custom buttons via block
      block

//- Toolbar separator
mixin dp-toolbar-sep()
  div.dp-toolbar-sep.self-stretch.my-1(style="width:1px; background:color-mix(in oklch, var(--color-base-content) 30%, transparent)")
