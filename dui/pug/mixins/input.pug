mixin filebox(opts)
  -
    // Force type to file
    var fileOpts = Object.assign({}, opts, { type: 'file' });
    // Replace 'input' class with 'file-input' for DaisyUI
    var classes = (fileOpts.class || '').split(' ').filter(c => c);
