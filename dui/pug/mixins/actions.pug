//- ============================================================================
//- MENUBUTTON — DaisyUI dropdown button with chevron indicator
//- ============================================================================
//- Usage:
//-   +menubutton#but_print.tbut(title="Reports" icon="printer" menu-id="dui-printmen")
//-   +menubutton(title="Theme" icon="sun" menu-id="theme-menu" position="end")
//-     each t in themes
//-       li.list-none: button.text-xs= t
//-
//- Attributes:
//-   title      — Button label text
//-   icon       — Feather icon name (optional)
//-   menu-id    — ID for the <ul> dropdown menu
//-   position   — Dropdown position: bottom (default), end, top, left, right
//-   menu-class — Extra CSS classes on the <ul> (e.g. "max-h-80 overflow-y-auto")
//- All other attributes pass through to the <button> element.
//- Block content goes into the <ul> menu.
//- ============================================================================
mixin menubutton(opts = {})
  - var title = attributes.title || ''
  - var icon = attributes.icon || ''
  - var menuId = attributes['menu-id'] || ''
  - var pos = attributes.position || 'bottom'
  - var menuCls = attributes['menu-class'] || ''
  - delete attributes.title
  - delete attributes.icon
  - delete attributes['menu-id']
  - delete attributes.position
  - delete attributes['menu-class']
  //- EUI compat — strip silently
  - delete attributes.plain
  - delete attributes.hasDownArrow
  - delete attributes.menu
  - var mbIconCls = attributes.iconCls || ''
  - delete attributes.iconCls
  - var mbResolvedIcon = icon || mbIconCls
  .dropdown.shrink-0(class='dropdown-' + pos)
    button.btn.btn-ghost.btn-sm.px-1.gap-1&attributes(attributes)(tabindex="0")
      if mbResolvedIcon
        +icon(mbResolvedIcon)
      span= title
      svg.w-3.h-3.opacity-60(fill="none" stroke="currentColor" viewBox="0 0 24 24")
        path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7")
    ul.dropdown-content.menu.menu-sm.bg-base-100.text-base-content.rounded-box.w-52.p-2.shadow-sm(id=menuId tabindex="0" class=menuCls style="z-index:1000")
      block

