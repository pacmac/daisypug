//- DaisyUI Button Mixin
//- Renders a DUI button with text and attributes
//- Signature: +button(text, vars)
//- Legacy EUI equivalent: linkbutton with icon support via iconCls
//- Classes: .btn (required), .btn-primary, .btn-secondary, .btn-lg, etc.

mixin button(text = '', vars = {})
  -
    // Normalize inputs — +button({icon:'save', color:'primary'}) without text
    if (typeof text === 'object') {
      vars = text;
      text = vars.text || '';
    }

    // Extract semantic params
    const icon = vars.icon || '';
    const color = vars.color || '';    // primary, secondary, accent, info, success, warning, error, neutral
    const size = vars.size || '';      // xs, sm, md, lg
    const style = vars.style || '';    // outline, ghost, link
    const shape = vars.shape || '';    // circle, square, wide, block

    // Resolve EUI iconCls via iconmap (if getIcon is available)
    var resolvedIcon = icon;
    if (!resolvedIcon && vars.iconCls) {
      resolvedIcon = (typeof getIcon === 'function') ? getIcon(vars.iconCls) : '';
    }

    // Build class string — semantic params first, then escape-hatch classes
    let btnClasses = 'btn';
    if (color) btnClasses += ' btn-' + color;
    if (size) btnClasses += ' btn-' + size;
    if (style) btnClasses += ' btn-' + style;
    if (shape) btnClasses += ' btn-' + shape;
    if (vars.class) btnClasses += ' ' + vars.class;
    if (vars.btnClass) btnClasses += ' ' + vars.btnClass;
    if (resolvedIcon) btnClasses += ' gap-1';

    // Build button attributes — spread vars, then remove non-HTML keys
    const btnAttrs = { ...vars };
    if (!btnAttrs.type) btnAttrs.type = 'button';
    delete btnAttrs.text;
    delete btnAttrs.btnClass;
    delete btnAttrs.class;
    delete btnAttrs.icon;
    delete btnAttrs.iconCls;
    delete btnAttrs.color;
    delete btnAttrs.size;
    delete btnAttrs.style;
    delete btnAttrs.shape;

  if resolvedIcon
    button&attributes(btnAttrs)(class=btnClasses)
      +icon(resolvedIcon)
      if text
        =text
  else
    button&attributes(btnAttrs)(class=btnClasses)=text


