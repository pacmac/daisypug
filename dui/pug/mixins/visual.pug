//- DaisyUI Components: mockup-browser, mockup-code, mockup-phone, mockup-window

//- ============================================================================
//- MOCKUP BROWSER
//- ============================================================================
mixin mockup_browser(url, opts)
  - var options = opts || {}
  .mockup-browser.border.bg-base-300&attributes(options)
    .mockup-browser-toolbar
      .input= url
    .bg-base-200
      block

//- ============================================================================
//- MOCKUP CODE
//- ============================================================================
mixin mockup_code(opts)
  - var options = opts || {}
  .mockup-code&attributes(options)
    block

mixin code_line(prefix, opts)
  - var options = opts || {}
  pre(data-prefix=prefix)&attributes(options)
    code
      block

//- ============================================================================
//- MOCKUP PHONE
//- ============================================================================
mixin mockup_phone(opts)
  - var options = opts || {}
  .mockup-phone&attributes(options)
    .mockup-phone-camera
    .mockup-phone-display
      block

//- ============================================================================
//- MOCKUP WINDOW
//- ============================================================================
mixin mockup_window(opts)
  - var options = opts || {}
  .mockup-window.border.bg-base-300&attributes(options)
    .bg-base-200
      block

