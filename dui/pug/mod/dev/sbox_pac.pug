block script
  script.
    $.page.ready(function() {
      // ── Toolbar sandbox — event log + eval ──────────────────────────
      (function() {
        var $log = $('#tb-log');
        var seq = 0;

        function tbLog(msg, cls) {
          seq++;
          var ts = new Date().toLocaleTimeString('en-GB', {hour12:false});
          var line = '<div class="' + (cls || '') + '">'
            + '<span class="opacity-40">' + ts + '</span> '
            + '<span class="opacity-50">[' + seq + ']</span> '
            + msg + '</div>';
          $log.append(line);
          $log[0].scrollTop = $log[0].scrollHeight;
        }

        // Wire all toolbar buttons — click event logging
        $('[id^="tb1_"], [id^="tb2_"], [id^="tb3_"], [id^="tb4_"], [id^="tb5_"], [id^="tb6_"], [id^="tb7_"], [id^="tb8_"]').on('click', function() {
          var id = this.id;
          var text = $(this).text().trim();
          var disabled = $(this).hasClass('pointer-events-none');
          if (disabled) {
            tbLog('<span class="text-warning">#' + id + '</span> (' + text + ') — disabled, no action', '');
          } else {
            tbLog('<span class="text-success">#' + id + '</span> (' + text + ') clicked', '');
          }
        });

        // Eval box
        function runEval() {
          var code = $('#tb-eval').val().trim();
          if (!code) return;
          tbLog('<span class="text-info">eval:</span> <span class="opacity-70">' + code.replace(/</g,'&lt;') + '</span>');
          try {
            var result = new Function('return ' + code)();
            if (result !== undefined) {
              tbLog('<span class="text-success">→</span> ' + String(result));
            }
          } catch(e) {
            tbLog('<span class="text-error">error:</span> ' + e.message);
          }
        }
        $('#tb-eval-run').on('click', runEval);
        $('#tb-eval').on('keydown', function(e) { if (e.key === 'Enter') runEval(); });

        // Clear log
        $('#tb-log-clear').on('click', function() { $log.empty(); seq = 0; });

        tbLog('<span class="opacity-50">Toolbar sandbox ready. Click buttons above or eval JS below.</span>');
        tbLog('<span class="opacity-50">Try: $(\'#tb2_add\').button(\'enable\')</span>');
      })();

