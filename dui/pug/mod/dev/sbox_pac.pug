          console.log('[checkTree] check:', node.id, node.text, checked);
        }
      });

      // ── Multibox sandbox ─────────────────────────────────────────────
      (function() {
        var $log = $('#mb-log');
        var seq = 0;

        function mbLog(msg) {
          seq++;
          var ts = new Date().toLocaleTimeString('en-GB', {hour12:false});
          $log.append('<div><span class="opacity-40">' + ts + '</span> <span class="opacity-50">[' + seq + ']</span> ' + msg + '</div>');
          $log[0].scrollTop = $log[0].scrollHeight;
        }

        // Update display text when checkboxes change
        function updateDisplay($mb) {
          var $text = $mb.find('.multibox-text');
          var checked = [];
          $mb.find('input:checkbox:checked').each(function() {
            checked.push(this.value);
          });
          if (checked.length === 0) {
            $text.text('Select items...').addClass('opacity-50');
          } else {
            $text.text('Selected Items (' + checked.length + ')').removeClass('opacity-50');
          }
          return checked;
        }

        // Wire checkbox change events for all three demos
        $('#mb-perms, #mb-dept, #mb-reports').each(function() {
          var $mb = $(this);
          var name = $mb.attr('id').replace('mb-', '');
          $mb.on('change', 'input:checkbox', function() {
            var checked = updateDisplay($mb);
            var action = this.checked ? 'checked' : 'unchecked';
            mbLog('<span class="text-info">' + name + '</span>: ' + action + ' <span class="text-accent">' + this.value + '</span> — total: ' + checked.length);
          });
        });

        // Get values — prototypes (raw DOM) + mixin versions (plugin API)
        $('#mb-get-vals').on('click', function() {
          ['mb-perms', 'mb-dept', 'mb-reports'].forEach(function(id) {
            var vals = [];
            $('#' + id).find('input:checkbox:checked').each(function() { vals.push(this.value); });
            mbLog('<span class="text-success">' + id + '</span>: ' + (vals.length ? vals.join(',') : '(none)'));
          });
          // Mixin versions via plugin API
          var mxMap = { 'mx-perms': 'MX_PERMS', 'mx-dept': 'MX_DEPT', 'mx-reports': 'MX_MODULES' };
          $.each(mxMap, function(id) {
            var $mb = $('[data-for="' + id + '"]');
            if ($mb.length) {
              var val = $mb.multibox('getValue');
              mbLog('<span class="text-success">' + id + '</span>: ' + (val || '(none)'));
            }
          });
        });

        // Set values programmatically
        $('#mb-set-vals').on('click', function() {
          // Prototype
          var $mb = $('#mb-perms');
          $mb.find('input:checkbox').prop('checked', false);
          ['View', 'Edit', 'Print'].forEach(function(v) {
            $mb.find('input:checkbox[value="' + v + '"]').prop('checked', true);
          });
          updateDisplay($mb);
          mbLog('<span class="text-warning">perms</span>: set to View,Edit,Print');
          // Mixin version
          var $mxPerms = $('[data-for="mx-perms"]');
          if ($mxPerms.length) {
            $mxPerms.multibox('setValue', 'View,Edit,Print');
            mbLog('<span class="text-warning">mx-perms</span>: set to View,Edit,Print');
          }
        });

        // Clear all
        $('#mb-clear').on('click', function() {
          // Prototypes
          $('#mb-perms, #mb-dept, #mb-reports').each(function() {
            $(this).find('input:checkbox').prop('checked', false);
            updateDisplay($(this));
          });
          // Mixin versions
          $('[data-for="mx-perms"], [data-for="mx-dept"], [data-for="mx-reports"]').each(function() {
            $(this).multibox('clear');
          });
          mbLog('<span class="text-error">all cleared</span>');
        });

        $('#mb-log-clear').on('click', function() { $log.empty(); seq = 0; });
        mbLog('<span class="opacity-50">Multibox sandbox ready. Try the dropdowns on the left.</span>');
      })();

      // Modal create demo
      $('#btn-modal-create').on('click', function() {
        var dlg = $.modal.create({
          id: 'sbox-demo',
          title: 'Demo Dialog',
          fields: [
            { id: 'PART_ID', type: 'combobox',  label: 'Part', sqlid: 'inv^partid_qbe' },
            { id: 'QTY',     type: 'numberbox', label: 'Quantity' },
            { id: 'STATUS',  type: 'combobox',  label: 'Status',
              data: [{ value: 'A', text: 'Active' }, { value: 'I', text: 'Inactive' }] }
          ]
        }, [
          { text: 'OK', handler: function() {
              var part = $('#sbox-demo [name="PART_ID"]').val();
              var qty  = $('#sbox-demo [name="QTY"]').val();
              var stat = $('#sbox-demo [name="STATUS"]').val();
              alert('Part: ' + part + ', Qty: ' + qty + ', Status: ' + stat);
              $('#sbox-demo').modal('close');
          }}
        ]);
        dlg.modal('open');
      });
    });
