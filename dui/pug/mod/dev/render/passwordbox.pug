extends ../../../layout/layout

block content
  +content("Passwordbox API Test", "Tests jQuery plugin API methods with DIRECT initialization (NO parser)")
    +section("Test Inputs", "Target elements for testing API methods")
      +form({cols: 2})
        +fitem("Target Passwordbox:")
          +passwordbox({id: 'target', class: 'input-bordered w-full', placeholder: 'Enter password...'})
        +fitem("Second Passwordbox:")
          +passwordbox({id: 'target2', class: 'input-bordered w-full', placeholder: 'Confirm password...'})

    +section("API Methods", "Click buttons to test each method")
      .grid.grid-cols-1.gap-4.mb-4(class="sm:grid-cols-2 lg:grid-cols-4")
        div
          h3.font-medium.mb-2 Value Methods
          .space-y-2
            button.btn.btn-sm.btn-primary.w-full#test-getValue getValue()
            button.btn.btn-sm.btn-primary.w-full#test-setValue setValue('secret123')
            button.btn.btn-sm.btn-primary.w-full#test-clear clear()
            button.btn.btn-sm.btn-primary.w-full#test-reset reset()

        div
          h3.font-medium.mb-2 Password Visibility
          .space-y-2
            button.btn.btn-sm.btn-secondary.w-full#test-showPassword showPassword()
            button.btn.btn-sm.btn-secondary.w-full#test-hidePassword hidePassword()
            button.btn.btn-sm.btn-secondary.w-full#test-togglePassword Toggle Visibility

        div
          h3.font-medium.mb-2 State Methods
          .space-y-2
            button.btn.btn-sm.btn-accent.w-full#test-disable disable()
            button.btn.btn-sm.btn-accent.w-full#test-enable enable()
            button.btn.btn-sm.btn-accent.w-full#test-readonly readonly()
            button.btn.btn-sm.btn-accent.w-full#test-readonly-false readonly(false)
            button.btn.btn-sm.btn-accent.w-full#test-options options()

        div
          h3.font-medium.mb-2 Inherited Methods
          .space-y-2
            button.btn.btn-sm.btn-info.w-full#test-textbox textbox()
            button.btn.btn-sm.btn-info.w-full#test-isValid isValid()
            button.btn.btn-sm.btn-info.w-full#test-resize resize(300)

    +section("Test Output", "Results from API method calls")
      +testOutput("output")
        | Click buttons above to test API methods.
        | Results will appear here...

    +section("Event Log", "Events (onChange, onBlur, onFocus) logged here")
      +testOutput("eventLog")

  //- Load dependencies in correct order
  script(src="/assets/js/textbox-helper.js")
  script(src="/assets/js/passwordbox-helper.js")

  //- Test script
  script.
    $(function() {
      var $output = $('#output');
      var $eventLog = $('#eventLog');

      // Helper to log output with visual separation
      function log(msg) {
        $output.append(msg + '\n');
        console.log(msg);
      }

      // Helper to log events
      function logEvent(msg) {
        var timestamp = new Date().toLocaleTimeString();
        $eventLog.append('[' + timestamp + '] ' + msg + '\n');
        console.log('[EVENT]', msg);
      }

      // Clear output on initialization
      $output.text('');
      $eventLog.text('');

      // Initialize passwordbox with options and event callbacks
      log('Initializing passwordbox with callbacks...');
      $('#target').passwordbox({
        value: 'password123',
        onChange: function(newVal, oldVal) {
          // Security: Don't log actual password values
          logEvent('onChange: password changed (length: ' + newVal.length + ')');
        },
        onBlur: function() {
          logEvent('onBlur');
        },
        onFocus: function() {
          logEvent('onFocus');
        }
      });

      // Initialize second passwordbox (no callbacks)
      $('#target2').passwordbox({
        value: 'confirm123'
      });

      log('Passwordbox initialized. Click buttons to test API methods.');
      log('─────────────────────────────────────────────────────────────────');
      log('');

      //- ====================================================================
      //- Value Methods Tests
      //- ====================================================================
      $('#test-getValue').click(function() {
        var val = $('#target').passwordbox('getValue');
        // Security: Don't log full password, just length
        log('► getValue() = "' + '*'.repeat(val.length) + '" (length: ' + val.length + ')');
      });

      $('#test-setValue').click(function() {
        $('#target').passwordbox('setValue', 'secret123');
        log('► setValue("secret123") - done');
      });

      $('#test-clear').click(function() {
        $('#target').passwordbox('clear');
        log('► clear() - done (password should be hidden)');
      });

      $('#test-reset').click(function() {
        $('#target').passwordbox('reset');
        log('► reset() - value reset to original (password should be hidden)');
      });

      //- ====================================================================
      //- Password Visibility Methods
      //- ====================================================================
      $('#test-showPassword').click(function() {
        $('#target').passwordbox('showPassword');
        log('► showPassword() - password revealed');
      });

      $('#test-hidePassword').click(function() {
        $('#target').passwordbox('hidePassword');
        log('► hidePassword() - password hidden');
      });

      $('#test-togglePassword').click(function() {
        var $input = $('#target');
        var currentType = $input.attr('type');
        if (currentType === 'password') {
          $input.passwordbox('showPassword');
          log('► Toggle: password revealed');
        } else {
          $input.passwordbox('hidePassword');
          log('► Toggle: password hidden');
        }
      });

      //- ====================================================================
      //- State Methods Tests
      //- ====================================================================
      $('#test-disable').click(function() {
        $('#target').passwordbox('disable');
        log('► disable() - input disabled');
      });

      $('#test-enable').click(function() {
        $('#target').passwordbox('enable');
        log('► enable() - input enabled');
      });

      $('#test-readonly').click(function() {
        $('#target').passwordbox('readonly');
        log('► readonly() - input is now readonly');
      });

      $('#test-readonly-false').click(function() {
        $('#target').passwordbox('readonly', false);
        log('► readonly(false) - readonly removed');
      });

      $('#test-options').click(function() {
        var opts = $('#target').passwordbox('options');
        log('► options() = ' + JSON.stringify(opts, null, 2));
      });

      //- ====================================================================
      //- Inherited Methods Tests
      //- ====================================================================
      $('#test-textbox').click(function() {
        var $elem = $('#target').passwordbox('textbox');
        log('► textbox() returned element: ' + $elem[0].tagName + ' with id=' + $elem.attr('id') + ', type=' + $elem.attr('type'));
      });

      $('#test-isValid').click(function() {
        var valid = $('#target').passwordbox('isValid');
        log('► isValid() = ' + valid);
      });

      $('#test-resize').click(function() {
        $('#target').passwordbox('resize', 300);
        log('► resize(300) - width set to 300px');
      });

      //- ====================================================================
      //- Initial status
      //- ====================================================================
      log('✅ All event handlers attached.');
      log('✅ Try typing in the input to see onChange events (values hidden for security).');
      log('✅ Try clicking in/out to see onFocus/onBlur events.');
      log('✅ Use show/hide buttons to toggle password visibility.');
      log('');
    });