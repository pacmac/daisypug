      "editor": { "type": "textbox", "options": { "readonly": true } } },
    { "field": "DESCRIPTION", "title": "Description", "width": 220,
      "editor": { "type": "textbox" } },
    { "field": "QTY", "title": "Qty", "width": 60, "align": "right",
      "editor": { "type": "numberbox", "options": { "precision": 0, "min": 0 } } },
    { "field": "STATUS", "title": "Status", "width": 80,
      "editor": { "type": "combobox", "options": {
