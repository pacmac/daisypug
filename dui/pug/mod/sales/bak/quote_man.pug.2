extends ../content
//- ── MIGRATOR ──────────────────────────────────
//- page: sales/quote_man
//- owner: CLS
//- status: clean
//- passes: 1  version: 6
//- last_run: 2026-02-27 14:58:13
//- ─────────────────────────────────────────────
block style
  style.
    div#toolbut {
      position: relative;
      top: -3px;
    }

    td[field=DESCRIPTION] > div {
      font-family: verdana;
      white-space: break-spaces !important;
    } 

    #DESCRIPTION_pop > textarea {
      font-family: verdana;
      white-space: break-spaces !important;
      width: 100%;
      height: 100%;
      border: none; 
      resize: none;    
    }
    
    td[field=_CB],
    td[field=LINE_NO] {
      background: linear-gradient(to bottom,#F9F9F9 0,#efefef 100%);
    } 
    
    td[field=LINE_NO] > .datagrid-cell,
    td[field=_CB] > .datagrid-cell {
      color: #000000;
    }
    
    form[class*="grid-"] {
      padding: 20px 22px 10px 0 !important;  
    } 
    
    form[class*="grid-"] .fitem {
      margin-right: 0;
    }

    #tbar {
      height:35px;
      line-height:35px;
      
    } #tbar > a {
      margin-left:12px;  
    }

block script
  //-script(src='html/eui/sales/js/quote_man.js')
  script: include js/quote_man.js
block content
  +vsplit('400px')
    +panel('west')
      +form#qhead(class='multi fit form', _sqlid='sales^quotehead', asdpx='adx')
        +hsplit('480px')
          +panel('north')

            +fitem('Quote ID',{id:'~', name:'QUOTE_ID', class:'qbe fkey fit navi autonum', panelWidth:'230px', validType:['length[1,30]']})
            +fitem('Quote Format',{name:'QUOTE_FORMAT', id:'~',_sqlid:'sales^quoteformatid', required:true, class:'combobox','data-options':"editable:false,panelHeight:'auto'"})
            +fitem('Title',{name:'DESCRIPTION', class:'textbox' , validType:['length[1,30]']})
            +fitem('Status / Revision',{name:'STATUS', id:'~', required:true, class:'combobox',style:'width:150px;','data-options':"editable:false,panelHeight:'auto'"})
              +input({name:'REVISION', id:'~', class:'numberspinner', precision:0, min:0,value:0,style:'width:50px;'})
                          
            +fitem('Customer ID',{name:'CUSTOMER_ID', id:'~', class:'combobox'})
            +fitem('Name',{name:'CUSTOMER_NAME',id:'~', class:'textbox' , validType:['length[1,80]']})

            +fitem('Currency',{name:'CURRENCY_ID', id:'~', class:'combobox',required:true,'data-options':"editable:false,panelHeight:'auto'"})
            +fitem('Payment Terms',{name:'PAYMENT_TERM', id:'~',  class:'combobox',required:true})
            +fitem('Status Remark',{name:'STATUS_REMARK',class:'textbox',readonly:true})
            +fitem('Total Value',{name:'GRAND',class:'numberbox',readonly:true, precision:2, prefix:'$'})
            
            +fieldset('Dates')
              +fitem('Quoted',{name:'QUOTE_DATE',id:'~', class:'datebox',required:true})
              +fitem('Follow Up',{name:'FOLLOWUP_DATE', id:'~',class:'datebox'})
              +fitem('Expiry',{name:'EXPIRY_DATE',id:'~', class:'datebox'})
              +fitem('Want',{name:'WANT_DATE', class:'datebox'})
          
          +panel('center')
            +tabs(data-options="plain:true,justified:true")
              +tab-item('Contact')
                +fitem('Contact Name',{name:'CONTACT_PERSON', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Phone',{name:'CONTACT_PHONE', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Fax',{name:'CONTACT_FAX', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Email',{name:'CONTACT_EMAIL', class:'textbox',validType:['email']})

              +tab-item('Ship To')
                +fitem('Address 1',{name:'SHIPTO_ADDR_1', class:'textbox',validType:['length[1,50]']})
                +fitem('Address 2',{name:'SHIPTO_ADDR_2', class:'textbox',validType:['length[1,50]']})
                +fitem('Address 3',{name:'SHIPTO_ADDR_3', class:'textbox',validType:['length[1,50]']})
              
              +tab-item('Notes')
                +tabs(data-options="plain:true,justified:true")
                  +tab-item('Order')
                    +fitem('NOTES ID',{id:'~',name:'NOTES_ID', _sqlid:'sales^quotenotesid', class:'combobox fit'}) 
                    .fitem(style="margin-top:0")
                      //-label(style="margin-bottom:8px;left:-8px;") Order Notes
                      +input({eui:'textbox',id:'~',name:'NOTES','data-options':"multiline:true", style:'height:150px;width:345px'})
                    div(style="margin-left:20px;margin-top:0")
                      p        any text appearing after @@@ will be printed as foot notes
                  +tab-item('Revision')
                    .fitem(style="margin-top:0")
                      //-label(style="margin-bottom:8px;left:-8px;") Revision Notes
                      +input({eui:'textbox',name:'REV_NOTES',id:'~', 'data-options':"multiline:true", style:'height:150px;width:345px'})
                  +tab-item('Quote Item')
                    .fitem(style="margin-top:0")
                      //-label(style="margin-bottom:8px;left:-8px;") Revision Notes
                      +input({eui:'textbox',id:'QI_NOTES', 'data-options':"multiline:true", style:'height:150px;width:345px'})
              +tab-item('Files')
                div(style="width:380px;")
                  +filegrid#qfiles(data-options="fit:true")
              +tab-item('UDF')
                +udfs({sqlid:'sales^udfid',select:bhave.UDF_LAYOUT_ID,ron:false})              
    +panel('center')
      #qlines

  div.hidden
    #linemenu.menu(style="width:120px;")
      div(name="insert" data-options="iconCls:'icon-insert'") Insert Line
    
    #savetemplatewin.dialog(title="Save as Template" data-options="closed:true,modal:true" style="padding:12px;")
      +form#saveastemplate
        +fitem('Quote ID',{id:'TEMPLATE_QUOTE_ID',class:'textbox',readonly:true})
        +fitem('Template ID',{id:'TEMPLATE_ID',class:'textbox upper',style:'',required:true, 'data-options':"validType:'length[1,50]'"})
        
        div(style="text-align:center;margin-bottom:0px;margin-top:12px")  
          a#saveastemplatebtn.linkbutton(data-options="iconCls:'icon-add'") Save
          a#close.linkbutton(data-options="iconCls:'aicon-cancel',onClick:function(){$('#savetemplatewin').dialog('close')}") Cancel
    #loadtemplatewin.dialog(title="Load Template" data-options="closed:true,modal:true" style="padding:12px;")
      +form#loadtemplate
        +fitem('Template ID',{id:'LOAD_TEMPLATE_ID',class:'combobox',_sqlid:'sales^quote_template_id' ,required:true})
        div(style="text-align:center;margin-bottom:0px;margin-top:12px")  
          a#loadtemplatebtn.linkbutton(data-options="iconCls:'icon-add'") Save
          a#close.linkbutton(data-options="iconCls:'aicon-cancel',onClick:function(){$('#loadtemplatewin').dialog('close')}") Cancel
    #copy_quote_menu(style="width:100px;")
      div(iconCls="icon-app") Copy Quote
        div
          div(name="NEW" iconCls="icon-add") New
          div(name="REVISION" iconCls="aicon-micrometer") Revision