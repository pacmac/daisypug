mixin oms_gauge_man_rental()
  .two
    div
      +h-group('General')
        +fitem('Term',{id:'~', name:'RENTAL_GAUGE_TYPE', class:'textbox', readonly:true})
        +oms_LICENSOR_ID('RENTAL_LICENSOR_ID')

      +h-group('Rental Costing')
        +fitem('Currency',{name:'RENTAL_CURRENCY', id:'~', class:'combobox' , _sqlid:'admin^curr', 'data-options':"panelHeight:'auto',editable:false"})
        +fitem('Daily Rate',{id:'~', name:'RENTAL_DAILY', class:'numberspinner', 'data-options':"precision:2, min:0, value:0, prefix:'$'"})

      +h-group('Royalty Costing')
        +fitem('Currency',{name:'ROYALTY_CURRENCY', id:'~', class:'combobox' , _sqlid:'admin^curr', 'data-options':"panelHeight:'auto',editable:false"})
        +fitem('Rate',{id:'~', name:'RENTAL_ROYALTY', class:'numberspinner', 'data-options':"precision:2, min:0, value:0, prefix:'$'"})
        +fitem('Type',{name:'GAUGE_ROYALTY_TYPE', id:'~', class:'combobox', 'data-options':"data:[{text:'ENDs Rate',value:'ENDS-RATE',selected:true},{text:'One Time Charge',value:'ONE-TIME'}], panelHeight:'auto',editable:false"})

    div
      +v-group('Long Term Rental',{id:'ltrental',class:'lock'})
        +fitem('Start Date',{id:'~', name:'RENTAL_LT_START', class:'datebox'})
        +fitem('Duration Days',{id:'~', name:'RENTAL_LT_PERIOD', class:'numberspinner', 'data-options':"precision:0, min:0, value:0"})
        +fitem('End Date',{id:'~', name:'RENTAL_LT_END', class:'datebox', readonly:true})

      +v-group('Specifications')
        +oms_GAUGE_RENT_DIAMETER()
        +oms_GAUGE_RENT_THREAD()
        +fitem('Pin or Box',{name:'GAUGE_RENT_PINBOX', class:'combobox', 'data-options':"data:[{text:'Pin',value:'PIN'},{text:'Box',value:'BOX'}],panelHeight:'auto',editable:false"})
        +fitem('Weight',{name:'GAUGE_RENT_WEIGHT', class:'textbox'})

  script.
    $('#OWNER_TYPE').combobox({
      onChange: function(nv,ov){
        setTimeout(function(){

          $('#RENTAL_GAUGE_TYPE').textbox('setValue',nv.toUpperCase());

          var ltr = $('#ltrental');
          var day = $('#RENTAL_DAILY');
          var per = $('#RENTAL_LT_PERIOD');
          var sd = $('#RENTAL_LT_START');  
          var tabs = $('#gmtabs'); cl(tabs);
          
          switch(nv){
            case 'owned':
              tabs.tabs('disableTab','Rental');
              day.numberspinner('readonly',false);
              ltr.addClass('lock');
              break;
            case 'short':
              tabs.tabs('enableTab','Rental');
              ltr.addClass('lock');
              day.numberspinner('readonly',false);
              break;
            case 'long':
              tabs.tabs('enableTab','Rental');
              ltr.removeClass('lock');
              day.numberspinner('readonly',true);
              day.numberspinner('setValue',0);
              break;
          }
               
        },100)
      }
    });
    
    $('#RENTAL_LT_PERIOD').numberspinner({
      onChange: function(nv,ov){
        var date = $('#RENTAL_LT_START').datebox('getDate'); 
        date.setTime(date.getTime()+(nv*24*60*60*1000));
        $('#RENTAL_LT_END').datebox('setValue',date); 
      }
    })
    
    $('#RENTAL_LT_START').datebox({
      onChange: function(nv,ov){
        var nv = $('#RENTAL_LT_PERIOD').numberspinner('getValue');
        var date = $('#RENTAL_LT_START').datebox('getDate'); 
        date.setTime(date.getTime()+(nv*24*60*60*1000));
        $('#RENTAL_LT_END').datebox('setValue',date);
      }
    })     
    
    
mixin oms_LICENSOR_ID(name)
  +fitem('Licensor',{name:name||'LICENSOR_ID', class:'combobox', _sqlid:'dqm^licensor_ids','data-options':"onChange:function(nv,ov){$('input[textboxname=GAUGE_RENT_THREAD]').combobox('load',{LICENSOR_ID:nv})},editable:false"})


mixin oms_GAUGE_RENT_THREAD()
  +fitem('Thread',{name:'GAUGE_RENT_THREAD', class:'combobox', _sqlid:'dqm^liccombo', 'data-options':"queryParams:{PARAM_TYPE:'THREAD'},editable:false"})

