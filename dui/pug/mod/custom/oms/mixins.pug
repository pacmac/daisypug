mixin oms_lists_rental()
  #licensor(title='Gauge Licensors')
    form.multi(_sqlid='dqm^licensor', asdpx='ax')
      +fitem('ID',{class:'combobox fkey fit', id:'~', name:'LICENSOR_ID', _sqlid_:'licensor_ids' ,'data-options':"validType:'length[1,30]',editable:false",required:true})
      +fitem('Name',{class:'textbox', name:'LICENSOR_NAME' ,'data-options':"validType:'length[1,80]'", required:true})

      +v-group('Rental Days Method') 
        +fitem('Mininum Days',{name:'MIN_DAYS', class:'numberspinner', 'data-options':"precision:0, min:0, value:0"})
      +v-group('Rental Formula')
        +fitem('Start Date',{class:'combobox', required:true, name:'LICENSOR_START_DATE', 'data-options':"data:[{text:'Ship Date', value:'SHIP_DATE'},{text:'Receipt Date', value:'RECEIPT_DATE'}],editable:false"}) 
        +fitem('End Date',{class:'combobox', required:true, name:'LICENSOR_END_DATE', 'data-options':"data:[{text:'Return Date', value:'RETURN_DATE'},{text:'Arrival Date', value:'RETURN_ARRIVAL_DATE'}],editable:false"})
    
      +v-group('Parameters',{style:'width:345px;height:250px;overflow:visible'})
        #licparam(_style="border-radius:6px;").radius
  
  script.
    $('#licparam').datagrid({
  
    }).datagrid('rowEditor',{
      
      tbarPrepend: $('<span style="float:right;padding:2px 4px;"><input class="combobox" style="width:180px" _sqlid="dqm^licparam_ids" /></span>'),
      cls:'radius-4',
      fitColumns: true,
      editor: 'inline',
      striped: true,
      url: '/',
       
      columns: [[
        {field:'LICENSOR_ID',hidden:true},
        {field:'PARAM_TYPE',hidden:true},
        {field:'PARAM_KEY',title:'ID',width:100,editor:'text'},
        {field:'PARAM_VALUE',title:'Text',width:200,editor:'text'}
      ]],
  
      onLoadSuccess: function(data){
      
      },
  
      onEndEdit: function(idx,row,chg){ 
        var me = $(this);
        var opt = me.datagrid('options');
        +combobox.tbarPrepend.find('input.easyui-combobox')
        var type = cbo.combobox('getValue');
        ajaxget('/',$.extend(row,{
          _sqlid:'dqm^licparam',
          PARAM_TYPE: type,
          LICENSOR_ID: $('#LICENSOR_ID').combobox('getValue') 
        }),function(res){
          cbo.combobox('reload');
          cl(res);  
        })
  
      }
    
    }).datagrid('editButs',{edit:'hide'});
    
    var dgo = $('#licparam').datagrid('options');
    
    +combobox.tbarPrepend.find.combobox('input.easyui-combobox')
      onSelect: function(rec){
        var dg = $('#licparam');
        dg.datagrid('load',{
          _sqlid:'dqm^licparam',
          _func: 'get',
          _combo: 'y',
          LICENSOR_ID: $('#LICENSOR_ID').combobox('getValue'),
          PARAM_TYPE:rec.value,
        })
        cl(rec);
      }
    })
    
    $('#licensor form').on('loadDone',function(jq,data){
      +combobox.tbarPrepend.find.combobox('input.easyui-combobox').combobox('reload')
    })