  $('#certbut > a').linkbutton({
    onClick:function(){
      var frm = $('#certfrm');
      var idx = frm.data('idx'); 
      var dg = $('#certdg');
      var me = $(this);
      var data = frm2dic(frm);
      //data.STAT = data.RESULT;
      
      if(me.attr('id')=='certdel') {
