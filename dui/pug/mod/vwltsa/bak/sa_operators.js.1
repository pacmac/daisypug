$.dui.page.settabs = function(appid){
  setTimeout(function(){

    $.dui.page.tabids = {
      udfen: 'User Fields',
      resen: 'Resources',
      certen: 'Certification',
      qualen: 'Qualifications',
      ncren:  'NCRs',
      docen: 'Attachments',
      rating:'Rating'
    }

    for(var t in $.dui.page.tabids){
      if($.dui.bhave[t] != 'n') var ed = 'enableTab';
      else var ed = 'disableTab'; 
      $('#optabs').tabs(ed,$.dui.page.tabids[t]);
    }
  },100)
}


$.dui.page.RATING=[{"text":"A","value":"A"},{"text":"B","value":"B"},{"text":"C","value":"C"},{"text":"Trainee","value":"T"}];
$.dui.page.ratingopts={
  twoColumns: false,
  editor:'form',
  rownumbers: false,
  fitColumns: true,
