extends ../content 
block content 
  #job_planner(style="height:100%;overflow-y:hidden;" asdpx="")
    table#resutil
    div#jptbar
block style
  style.

    .datagrid-header-row td.off {
      background:#DDDDDD;
    }

    .datagrid-row-over {
      background: inherit;
    }

    .datagrid-body td {
      vertical-align: top;
    }
    
    .pct {
      background-repeat:no-repeat;
      background-position: bottom;
    }
    
    .ulbar {
      list-style-type: none;
      margin: 2px 0;
      padding: 0;
      xbackground: #EEEEEE;
      background-image: url("../img/ora-0.5.png");
      background-repeat: no-repeat;
      background-position: bottom;
      background-size: 100% 0;
    } .ulbar li {
      min-height:18px;
      border-bottom: 1px solid white;
      text-align:center;     
    } 
    
    .ulbar.ora, .pct.ora { background-image: url("../img/ora-0.5.png");}
    .ulbar.grn, .pct.grn { background-image: url("../img/grn-0.5.png");}
    .ulbar.red, .pct.red { background-image: url("../img/red-0.5.png");}
    .ulbar.gry, .pct.gry { background: #DDDDDD;}
block script     
  script: include js/dg_resutil.js