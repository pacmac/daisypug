    { "field": "UNIT_COST", "title": "Unit Cost", "width": 80, "fixed": true, "align": "right", "formatter": "eui.currency" },
    { "field": "TOTAL_COST", "title": "Total Cost", "width": 80, "fixed": true, "align": "right", "formatter": "eui.currency" },
    { "field": "DESCRIPTION", "title": "Description", "width": 200, "fixed": true }
  ]
