extends ../content
block content
  +vsplit('400px')
    +panel('west')
      +form#wip_count(class='multi fit form', _sqlid='inv^wip_count', asdpx='adx')
        //- [MANUAL FIX] +split inside +form — causes double margins. Move the split above the +form. Downgraded to +layout until fixed.
        +vsplit('400px')
          +panel('north', { style: "height:500px" })
            +fitem('WIP Count ID',{id:'~', name:'WIP_COUNT_ID',class:'combobox fkey fit navi autonum', _sqlid:'inv^wip_count_ids' , panelWidth:'230px', validType:['length[1,30]'],'data-options':"groupField:'STATUS'"})
            +fitem('Job Class',{id:'~', name:'WO_CLASS', class:'combobox',_sqlid:'inv^wip_count_jobclassids'})
            +fitem('Start Date',{id:'~',name:'START_DATE', class:'datebox today'})
            +fieldset('End Count')
              +fitem('Date',{'id':'~',name:'END_DATE', class:'datebox'})
              +fitem('User',{'id':'~',name:'END_COUNT_USER',class:'textbox',readonly:true})
            .fbuts.center
              a.linkbutton#endcount(icon='icon-verified' style="margin-left:10px;margin-top:5px" ) End Count
            +fitem('User Password',{'id':'pwd',class:'textbox',type:'password'})
            .fitem(style="margin-top:12px")
              +label('Notes')
              +input({eui:'textbox',id:'~', name:'NOTES','data-options':"multiline:true", validType:['length[1,255]'], style:'height:150px;width:345px'})           
    +panel('center')
      div#shipdiv
        +datagrid#lines
block script
  +script("inv",['js/wip_count.js'])
  script.
    console.warn('[audit] wip_count L6: +split inside +form — causes double margins. Move the split above the +form. Downgraded to +layout until fixed.')
