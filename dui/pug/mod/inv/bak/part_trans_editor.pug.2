extends ../content
block content
  +vsplit('410px')
    +panel('west')
      +form#parttrans(style="display:inline")
        +fitem('Part ID',{name:'PART_ID', readonly:true,requiredx:true,class:'textbox'})
        +fitem('Tx ID',{name:'TRANSACTION_ID', readonly:true,class:'textbox'})
        +fitem('Document ID',{name:'DOCUMENT_ID', class:'textbox'})
        +fitem('Tx Date',{name:'TRANSACTION_DATE',  class:'datebox'})  
    +panel('center')
      
      #tbar
        +form#gfilter
          //-+label('From')
          //-input.datebox.today(name="sdate" style="width:100px;")
          +fitem('From',{name:'a',class:'databox today'})
          //-+label('To')
          //-input.datebox.today(name="edate" style="width:100px;")
          +fitem('To',{name:'a',class:'databox today'})
          //-+label('Part ID')
          //-input.combobox(_sqlid="inv^partid" name="pid" )
          +fitem('Part ID',{name:'pid',_sqlid="inv^partid", readonly:true,requiredx:true,class:'combobox'})
      +datagrid#txgrid
block script
  //-+script("inv",['js/part_trans_editor.js'])
  script: include js/part_trans_editor.js
block style
  style.
    #parttrans .fitem{
      margin-bottom: 8px !important;
    }    
    #tbar {
      height:30px;
      line-height:30px;  
      margin-top:10px;
    } #tbar label {
      margin-left:16px;
      margin-right:4px;  
    }
