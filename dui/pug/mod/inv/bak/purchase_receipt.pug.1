extends ../content
block script
  script: include js/purchase_receipt.js
block style
  style.
    div#toolbut {
      position: relative;
      top: -3px;
    }
    td[field=LINE_NO] {
      background: linear-gradient(to bottom,#F9F9F9 0,#efefef 100%);
    } td[field=LINE_NO] > .datagrid-cell {
      color: #000000;
    }
    form[class*="grid-"] {
      padding: 20px 22px 10px 0 !important;  
    } 
    form[class*="grid-"] .fitem {
      margin-right: 0;
    }


block content
  +layout({border:false})
    +panel('west', { style: "width:400px; background:#FAFAFA;", collapsible: "false" })
      +form#receipthead.multi.fit(_sqlid='inv^receipt_head' asdpx='adx')
        +layout({border:false})
          +panel('north', { style: "height:250px;background:#FAFAFA;" })
            +fitem('Receipt ID',{id:'~', name:'RECEIPT_ID', class:'qbe fkey fit navi', panelWidth:'230px', validType:['length[1,30]']})
            +fitem('Order ID',{id:'~', name:'PO_ID', class:'qbe', required:true,panelWidth:'230px', validType:['length[1,30]']})                         
            +fitem('Vendor ID',{name:'VENDOR_ID', id:'~' ,class:'textbox',readonly:true})
            +fitem('Name',{id:'~',name:'NAME', class:'textbox',readonly:true})
            +fitem('Delivery Date',{name:'DELIVERY_DATE', class:'datebox',readonly:true})
            +fitem('Actual Delivery Date',{name:'ACT_DELIVERY_DATE', class:'datebox today'})
            +fitem('Exch Rate',{name:'CURRENCY_RATE', class:'numberbox' ,readonly:true,precision:8})
          +panel('center', {  })
            +tabs(data-options="plain:true,justified:true")
              div(title="Contact")
                +fitem('Name',{id:'~',name:'CONTACT_PERSON', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Phone',{id:'~',name:'CONTACT_PHONE', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Fax',{id:'~',name:'CONTACT_FAX', class:'textbox' ,validType:['length[1,80]']})
                +fitem('Email',{id:'~',name:'CONTACT_EMAIL', class:'textbox',validType:['email']})
              div(title="Notes")
                .fitem(style="margin-top:0")
                  label(style="margin-bottom:8px;left:-8px;") Order Notes
                  +input({eui:'textbox',name:'NOTES','data-options':"multiline:true", style:'height:150px;width:345px'})
              div.files(title='Files' fit="true" _iconCls="icon-pclip" style="padding:4px 0 0 4px")
                div(style="width:380px;")
                  +filegrid#pofiles(data-options="fit:true")
                  
    +panel('center', {  })
      #receiptlines
    +dialog#traced(style="width:500px;height:250px;" title="Trace/Dimensions Details" closed="true" modal="true")
      #tracedg