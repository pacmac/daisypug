//- Part Number Generator Modal
//- Included by sa_parts.pug — uses +modal, +fitem, +modal-footer from feedback.pug

style.
  #pngenwin #genhead,
  #pngenwin #generator {
    --fitem-label-w: 140px;
  }
  #pngenwin #genhead .frow > label,
  #pngenwin #generator .frow > label {
    text-transform: capitalize;
  }

+modal#pngenwin(title="Add New Part", max-w="lg", no-form)
  form
    div#genhead
      +fitem('Class ID',{id:'GEN_CLASS_ID', class:'combobox'})
      br
    div#generator.hidden_
    div#results
      +fitem('Part ID',{id:'GEN_ID', class:'textbox', readonly:true, validType:['length[1,30]']})
      +fitem('UOM',{id:'GEN_UOM', class:'textbox', readonly:true})
      +fitem('Traceable',{id:'GEN_TRACEABLE', class:'combobox', readonly:true, 'data-options':"data:[{text:'Yes',value:'Y'},{text:'No',value:'N'}]"})
      +fitem('Description',{id:'GEN_DESC', class:'textbox', readonly:true, 'data-options':"multiline:true,height:100"})
  +modal-footer
    button#butgo.btn.btn-primary.btn-sm(disabled) Apply
script: include js/pn_gen.js

