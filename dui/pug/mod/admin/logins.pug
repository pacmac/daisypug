block content
  +hsplit('70%')
    +panel('north')
      +datagrid#logins
    +panel('center')
      +datagrid#dgvwlogs
  +modal(title="Send User Message" no-form max-w="lg")#user_msg
    +fitem('Message', {id: 'user_msg_text', name: 'user_msg_text', class: 'textarea textarea-bordered', rows: 4, value: 'Dear $userid;\\n\\nCan you please log out briefly so we can apply some updates.\\n\\nThank You.'})
    +modal-footer
      +button('Send', {id: 'user_msg_send', size: 'sm', color: 'primary', icon: 'send'})
