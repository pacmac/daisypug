        +fitem('Database Type',{id:'~',name:'engine', class:'combobox'})
        +fitem('Server',{name:'server', class:'textbox',required:true})
        +fitem('Database',{name:'database', class:'textbox',required:true})
        +fitem('User Name',{name:'userName', class:'textbox',required:true })
        +fitem('Password',{name:'password', class:'textbox',required:true ,type:'password'})
        +fitem('Use Pooling',{id:'~',name:'pooling', class:'combobox', 'data-options':"data:[{value:true,text:'YES'},{value:false,text:'NO'}]"})
