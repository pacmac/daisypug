extends ../content 

block style
  style.
    #coinfo a.textbox-icon.icon-login {
      pointer-events: all;
      position: relative;
      top: -60px;
      right: 4px;
      opacity:1;
    }

block script
  +script("admin",['js/global.js'])
  script.
    $('#lickey').filebox({
      multiple: false,
      accept:'.key',
      onChange: function(nv,ov){
        $(this).textbox('textbox')[0].value = nv.replace("C:\\fakepath\\", "");
        var f = $(this).data('filebox').filebox.children('input[type=file]')[0].files[0];
    
        var name = f.name;
        if((/\.key/).test(name)){
          var reader = new FileReader();
          reader.onload = function(evt){
            var data = evt.target.result.trim();
            $('#colkey').textbox('setValue',data);
            msgbox('License updated, please save.')
            try{$('#lickey').filebox('clear')}
            catch(err){}
          }       
          
          reader.readAsText(f);
        }
        else msgbox('*.key files only.')
      } 
    })
    
    // bug fixes / hacks
    setTimeout(function(){
      $('#coinfo a.textbox-icon.icon-login').removeClass('textbox-icon-disabled');
      $('#lickey').next('span.filebox').find('input[type="file"]').attr('accept','.key');
    });
    
block content
  +tabs#main(fit="true")
    
    #coinfo(title='Company' iconCls="aicon-table")
      form.single.load(_sqlid='admin^company' asdpx='s')
        div.two
          div(style="width:420px;")
          
            +fieldset('Registered Address',{style:'margin-top:12px;'})
              +fitem('Name',{name:'coname', class:'textbox',required:true })
              +fitem('Address Line 1',{name:'coaddr1', class:'textbox' })
              +fitem('Address Line 2',{name:'coaddr2', class:'textbox' })
              +fitem('Address Line 3',{name:'coaddr3', class:'textbox' })
              +fitem('Telephone',{name:'cotel', class:'textbox' })
              +fitem('Fax',{name:'cofax', class:'textbox' })
            +fieldset('Emails',{style:'margin-top:12px;'})
              +fitem('Help Desk',{name:'helpdesk_email', class:'textbox',required:true  })
              +fitem('Administrator',{name:'administrator_email', class:'textbox' ,required:true })
            +fieldset('Remit-To Address',{style:'margin-top:12px;'})
              +fitem('Name',{name:'remitname', class:'textbox' })
              +fitem('Address Line 1',{name:'remitaddr1', class:'textbox' })
              +fitem('Address Line 2',{name:'remitaddr2', class:'textbox' })
              +fitem('Address Line 3',{name:'remitaddr3', class:'textbox' })
              +fitem('Telephone',{name:'remittel', class:'textbox' })
              +fitem('Fax',{name:'remitfax', class:'textbox' })          

            div.center
              //-img(src=$.__cologo || "img/cologo.png" style="height:100px;")
              img(src="img/cologo.png" style="height:100px;")
                    
          div

            +fieldset('Company Info',{style:'margin-top:12px;'})
