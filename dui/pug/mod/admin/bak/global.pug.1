              +fitem('Minimum Upper',{name:'pwd_rule_ucase', class:'numberspinner' ,required:true,value:1,min:0,max:5,precision:0 })
              +fitem('Minimum Lower',{name:'pwd_rule_lcase', class:'numberspinner' ,required:true,value:1,min:0,max:5,precision:0 })
              +fitem('Minimum Numeric',{name:'pwd_rule_numeric', class:'numberspinner' ,required:true,value:1,min:0,max:5,precision:0 })
              +fitem('Minimum Special',{name:'pwd_rule_special', class:'numberspinner' ,required:true,value:1,min:0,max:5,precision:0 })
          .div
            +fieldset('User access',{style:'margin-top:12px;'})
              +fitem('Idle Minutes',{name:'idlemin',class:'numberspinner',value:0,min:0,max:60,precision:0})  
              +fitem('Inactive Days',{name:'inactive_days',class:'numberspinner',value:0,min:0,max:365,precision:0})            
              +fitem('Allow Remote Access',{id:'RA', name:'remote_access'})
              div#iplist
                +fitem('Allowed IPs',{id:'ip',name:'ip', class:'textbox', 'data-options':"multiline:true",style:'height:200px;'})

   
    #sa_database(title='Databases' iconCls="aicon-database")          

      form.multi(_sqlid='admin^dbcon' asdpx='asx')
