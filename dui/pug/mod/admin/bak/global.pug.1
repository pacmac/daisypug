              +fitem('Site UID',{name:'couid', class:'textbox' ,readonly:true})
              +fitem('Group UID',{name:'groupuid', class:'textbox' ,readonly:true})
              +fitem('Home Currency',{name:'currency_id', class:'combobox' , _sqlid:'admin^curr'})
              +fitem('Costing Currency',{name:'costing_currency_id', class:'combobox' , _sqlid:'admin^curr',required:true})
              +fitem('Default GST Code',{name:'gst_id', class:'combobox' , _sqlid:'admin^gst'})

            +fieldset('Licensing',{style:'margin-top:12px;'})
              .hide
                +input({id:'lickey', class:'filebox hide',accept:'.key'})
              +fitem({text:'License Key',style:'vertical-align:top'},{id:'~',name:'colkey', required:true, class:'textbox' ,readonly:true,'data-options':"multiline:true,icons:[{disabled:false,iconCls:'icon-login',class:'lickey',handler:function(){$('#lickey').next().find('.textbox-value')[0].click()}}]",style:'height:150px;'})
              +fitem('Office Users',{id:'ucount', class:'numberbox sub-off' ,readonly:true, value:$.license.allow})
              +fitem('Support Expires',{class:'datebox sub-off' ,readonly:true, value:$.license.amexpire})
              +fitem('Agreement Docs',{id:'_agree', class:'combobox sub-off'})
              if(!$.isbin)
                div
                  +fitem('Pure Version',{name:'appver', class:'textbox' ,readonly:true,value:$.package.version }) 
              //-+fitem('Shop Floor Devices',{id:'dcount', class:'numberbox sub-off' ,readonly:true, value:$.license.vwlt})    
              //-+fitem('Enabled Modules',{id:'licmod', class:'textbox sub-off' ,readonly:true, value:$.license.mod})
              //-+fitem('System Restart ?',{name:'_restart', required:true, class:'combobox', 'data-options':"data:[{value:'y',text:'Yes'},{value:'n',text:'No'}]" }) 
              
    #eserver(title='Email Server' iconCls="icon-email")
      form.single.load(_sqlid='admin^eserver' asdpx='s')
        +fitem('Method',{id:'logon',name:'logon', class:'textbox fkey' ,required:true})
        
        div#smtp
          +fitem('Host IP or Name',{name:'host', class:'textbox' ,required:true})
          +fitem('Host Port',{name:'port', class:'numberbox' ,required:true ,value:25})
          +fitem('Domain Name',{name:'domain_name', class:'textbox' })
          fieldset#login  
            +fitem('Host User',{id:'emuser',name:'user', class:'textbox' })
            +fitem('Host Password',{id:'empass',name:'pwd', class:'textbox' ,type:"password"}) 
        +fitem('Test Recipient',{id:'testrecip', class:'easyui-validatebox' ,'data-options':"validType:'email'" ,value:"purehelp@dis.com.sg"})      
        .fbuts.center
          a#testmail

    #security(title='Security' iconCls="icon-lock")
      form.single.load(_sqlid='admin^security' asdpx='s')
        .div.two
          div(style="width:420px;")
            +fieldset('Password Rules',{style:'margin-top:12px;'})
