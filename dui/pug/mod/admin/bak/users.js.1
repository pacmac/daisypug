$.dui.page.user_auth=function(rec){
  var endis='enable';
  if (rec.user_auth>9) endis='disable';
  $('#user_auth').combobox(endis);
}


// Called by Authority - report checkapps.
$.dui.page.appreps = function(node,chk){
  var tr = $("#reports");
  var opt = tr.tree('options');
  opt.checkLock = true;
  var reps = tr.tree('getChildren'); 
  var ids=[]; reps.map(function(e,i){if(e.app == node.id) ids.push(e)})
  ids.map(function(e,i){   
    if(i==ids.length-1) opt.checkLock = false;
    if(chk) tr.tree('check',e.target);
    else tr.tree('uncheck',e.target);
  })
}

// Reset all User Reports.
$.dui.page.represet = function(){
  var tr = $("#reports");
  var opt = tr.tree('options');
  var ua = $('ul#adm_auth_t');
  var apps = ua.tree('getChildren');
  var reps = tr.tree('getChildren'); 
  var ids=[]; 
  
  apps.map(function(app,i){
    reps.map(function(e,i){
      if(e.app == app.id) {
        e.checked = app.checked;
        ids.push(e);
      }
    })    
  })

  opt.checkLock = true;
  ids.map(function(e,i){   
    if(i==ids.length-1) opt.checkLock = false;
    if(e.checked) tr.tree('check',e.target);
    else tr.tree('uncheck',e.target);
  })
}

// set REPORTS Tree.
$.dui.page.rp = function(rec,data){
  //$.dui.page.udata(rec);
  var ug = $("#reports");
  ug.data('lock',true).css('opacity',1);
  var roots = ug.tree('getChecked');
  for(var i in roots){ug.tree('uncheck',roots[i].target);};  
  
  ajaxget('/',{
    _func: 'get',
    _sqlid: 'admin^usersreports',
    userid: rec.value  
  },function(data) {
    if(!Array.isArray(data)) data=[data];
    data.map(function(e){
      var grp = ug.tree('find',e);
      if(grp) ug.tree('check',grp.target);      
    })
    
    ug.data('lock',false);
  })
}

