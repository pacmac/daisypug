// set user authority tree
$.dui.page.ua = function(rec){
  
  function iter(mod,umens){
    for(var i in mod){
      if(mod[i].children) iter(mod[i].children,umens);
      else {
        $(mod[i].target).removeClass('ronly');
        if(umens.indexOf(mod[i].id+'.ro') !== -1){
          os.tr.tree('check',mod[i].target);
          $(mod[i].target).addClass('ronly');
          os.tr.tree('update',{'target':mod[i].target,'ronly':true});
        } 
        else if(umens.indexOf(mod[i].id) !== -1) os.tr.tree('check',mod[i].target);
      }
    }        
  }
  
  var os = {tr:$("#adm_auth_t")};
  os.tr.data('lock',true).css('opacity',1);
  os.tr.tree('getRoots').map(function(e){os.tr.tree('uncheck',e.target)})
  os.tr.tree('getLeafs').map(function(e){
    os.tr.tree('uncheck',e.target);
    $(e.target).removeClass('ronly');
    os.tr.tree('update',{'target':e.target,'ronly':false});
  }) 
  
  os.url = gurl('/?_func=get&_sqlid=admin^auth&userid='+rec.value);
  ajaxget(os.url,{},function(data) {
    os.umens  = JSON.parse(data.menus);
    for(var mod in os.umens){
      os.mod = os.tr.tree('find',mod);
      if(os.mod) iter(os.mod.children,os.umens[mod]);
    }
    os.tr.data('lock',false);
  })
}

// readonly append .ro
$.dui.page.ronly = function(men){
  var tr = $('ul#adm_auth_t'); 
  var sel = tr.tree('getSelected');
  var tgt = $(sel.target);
  if(!sel.checked && !tgt.hasClass('ronly')) return;
  tgt.toggleClass('ronly');
  var dat = {'target':sel.target,'ronly':true}
  if(!tgt.hasClass('ronly')) dat.ronly = false;
  tr.tree('update',dat);
  $.dui.page.uastat();
}

$.dui.page.uastat = function(dbug){
  var oc = {sel:$('ul#adm_auth_t').tree('getChecked',['checked','indeterminate']),list:[],umen:{}};
  oc.userid = $('input[name="userid"]').val();
  
  oc.sel.map(function(e,i){
    var mod = e.id.split('^')[0];
    if(!oc.umen[mod]) oc.umen[mod] = [];
    var id = e.id; if(e.ronly) var id = e.id+'.ro';
    oc.umen[mod].push(id);
  })

  ajaxget('/',{
    _func:'upd',
    _sqlid:'admin^umenus',
    menus: JSON.stringify(oc.umen),
    userid: oc.userid
  });
}

