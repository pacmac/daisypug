$.dui.page.efrm = $('#eserver > form');
$.dui.page.logon = $('#logon');
$.dui.page.login = $('#login');
$.dui.page.emup = $('input#emuser,input#empass');

$.dui.page.logonsel = function(rec){
  switch(rec.value){
    case "smtp":
    case "smtpa":
      $('#smtp').show();
      if(rec.value == 'smtpa'){
        $.dui.page.login.show();
        $.dui.page.emup.textbox('required',true); 
      } else {
        $.dui.page.login.hide();
        $.dui.page.emup.textbox('required',false);         
      }
      break;
    default:
      $('#smtp').hide();
      $.dui.page.emup.textbox('required',false);       
  }
}

$.dui.page.logon.combobox({
  panelHeight:'auto',
  data: [{text:'NONE',value:'none'},{text:'SMTP',value:'smtp'},{text:'SMTP-LOGIN',value:'smtpa'}],
  onSelect: $.dui.page.logonsel
});


