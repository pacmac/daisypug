extends ../content
block script
  script: include js/gauge_man.js
block content
  form#gauge.multi(_sqlid='dqm^gauges', asdpx='xa' mode="add" data-lbut="x" data-ebut="nsx").fit
    +vsplit('400px')
      +panel.bg-base-200('west')
        input(type='hidden' name='NUMBERING')#NUMBERING
        //-.fitem
          label Asset ID
          +combobox#GAUGE_ID.fkey.fit(data-options="groupField: 'GAUGE_TYPE',formatterx:cbocols,xwidths:['50%','50%'], xdgcol:{'value':'value','text':'text','DESCRIPTION':'Description'}" name='ID' _sqlid='dqm^gauge' )
        +fitem('Asset ID',{id:'GAUGE_ID', name:'ID', class:'qbe fkey fit navi', panelWidth:'230px', validType:['length[1,30]']})  
        +fitem('Asset Type',{id:'~',name:'GAUGE_TYPE',class:'combobox',_sqlid:'dqm^gaugeType',required:'required','data-options':{editable:false}})


        //-.fitem
          label Asset Class
          +combobox(name='GAUGE_CLASS' data-options="validType:['inList'],editable:false,data:[{value:'ref',text:'Reference'},{value:'master',text:'Master'}, {value:'gauge',text:'Working Gauge'}, {value:'facility',text:'Facility Equipment'}, {value:'Licenses',text:'Licenses'}],panelHeight:'auto'")
        +fitem('Asset Class',{name:'GAUGE_CLASS',class:'combobox',"data-options":"validType:['inList'],editable:false,data:[{value:'ref',text:'Reference'},{value:'master',text:'Master'}, {value:'gauge',text:'Working Gauge'}, {value:'facility',text:'Facility Equipment'}, {value:'Licenses',text:'Licenses'}],panelHeight:'auto'"})
        +fitem('Description',{id:'~',name:'DESCRIPTION'})

        +fitem('Owner ID',{id:'~',name:'DEPARTMENT_ID',class:'combobox',_sqlid:'dqm^department',"data-options":"validType:['inList'],editable:false"})
        //-.fitem
          label Owner ID
          +combobox(name='DEPARTMENT_ID' _sqlid='dqm^department' data-options="validType:['inList'],editable:false")
        .fitem
          label Ownership
          +combobox#OWNER_TYPE(name='OWNER_TYPE' required="required"  data-options="validType:['inList'],editable:false,data:[{value:'short',text:'Rental, Short Term'},{value:'long',text:'Rental, Long Term'}, {value:'owned',text:'Self Owned'}],panelHeight:'auto'")
        +fitem('Store / Location',{name:'LOCATION',class:'textbox'})
        +fitem('Received Date',{name:'ACQUIRED_DATE' ,class:'datebox today',readonly:"readonly"})
        +fitem('Dispose / Return Date',{name:'RETURN_DATE' ,class:'datebox',readonly:"readonly"})
        +fitem('Serial Number',{name:'SERIAL_NO',class:'textbox'})

        +fitem('Plan ID',{name:'PLAN_ID',id:'~',class:'combobox'})
        //-  label 
          +combobox#PLAN_ID(name="PLAN_ID" _sqlidx="qt_qpid" data-optionsX="validType:['inList']")
        
        +fitem('Last Transaction',{id:'LAST_TX',class:'textbox',readonly:"readonly"})      
        
        .fitem
          label Status
          +combobox#STATUS(name='STATUS' required='required' _sqlid="dqm^gaugestatusid_gaugeman" data-options="editable:false,validType:['inList']")

      +panel('center')
        +tabs#gmtabs(fit="true")
          +tab-item('Calibration', {iconCls:'icon-date', style:'padding:12px 8px'})

            .fitem
              label Calibration Method
              +combobox(name='CAL_TYPE' data-options="validType:['inList'],editable:false,panelHeight:'auto', data:[{value:'VERIFY',text:'VERIFY ONLY'},{value:'TEST',text:'INTERNAL TEST'},{value:'EXTERNAL',text:'EXTERNAL TEST'}],editable:false" required="required")

            +fieldset('Initial Calibration')
              +fitem('First Calibration',{id:'~',name:'CALDAYS_1',class:'numberspinner',precision:'0',suffix:' Days'})
              +fitem('Second Calibration',{id:'~',name:'CALDAYS_2',class:'numberspinner',precision:'0',suffix:' Days'})
            
            +fieldset('Periodic Calibration')
              .fitem(style="margin-bottom:8px")
                label Frequency Units
                +combobox#CYCLE_TYPE(data-options="data:[{text:'DAYS',value:'DAYS'},{text:'WEEKS',value:'WEEKS'},{text:'MONTHS',value:'MONTHS'}],editable:false" name="CYCLE_TYPE" required='required' value='MONTHS')
              
              +fitem('Frequency Value',{id:'~',name:'CYCLE_TIME',class:'numberspinner',precision:'0',required:'required',value:'1'})
              +fitem('Due Alert Days',{id:'~',name:'DUE_DATE_ALERT_DAYS',class:'numberspinner',precision:'0',required:'required'})

            +fieldset('Last Calibration')
              +fitem('Completed Date',{id:'~',name:'LAST_CAL',class:'datebox',readonlyx:'readonly'})            
              +fitem('Doc. Reference',{id:'~',name:'DOC_REF',class:'textbox',editable:'false'})
              +fitem('Calibrated By',{id:'~',name:'CAL_BY',class:'textbox',readonlyx:'readonly'}) 

            +fieldset('Next Calibration ')        
              +fitem('Due Date',{id:'~',name:'DUE_DATE',class:'datebox'})
              +fitem('Usage Count',{id:'~',name:'CYCLE_COUNT',class:'numberbox',readonly:'readonly',value:'0'})
              +fitem('Total Count',{id:'~',name:'TOTAL_COUNT',class:'numberbox',readonly:'readonly',value:'0'})
          +tab-item('Specification', {iconCls:'file-text'})
            +fitem('Manufacturer',{name:'MANUFACTURER',class:'textbox'})
            +fitem('Model',{class:'textbox',name:'MODEL'})
            +fitem('Operating Range',{id:'RANGE',class:'textbox',name:'OP_RANGE'})
            +fitem('Operating Tolerance',{name:'TOLERANCE',class:'textbox'})
            .fitem(style="margin-top:0")
              label(style="margin-bottom:8px;") Notes / Specs
              div(style="margin-left:140px;height:98%;margin-top:-16px;")
                +input({eui:'textbox',name:'NOTES','data-options':"multiline:true", style:'height:150px;width:205px'})

          +tab-item('Test Results', {iconCls:'icon-doc-ok'})
            +hsplit('50px')
              +panel('north').bg-base-200.noborder(style="padding:12px 0 0 8px")
                
                .fitem.inline
                  label(style="width:auto;margin-right:12px;font-weight:bold;") Test ID
                  input#calids(style="width:120px; margin-right:12px;").navi
      
                div(style="min-width:20px;display:inline-block;margin-left:25px;")
                  label(style="width:auto;margin-right:12px;font-weight:bold;") Status
                  +textbox#teststatus(style="width:80px;" readonly="readonly")
      
                div(style="min-width:20px;display:inline-block;margin-left:25px;")
                  label(style="width:auto;margin-right:12px;font-weight:bold;") Date
                  +textbox#caldate(style="width:80px;" readonly="readonly")
                
                div(style="min-width:20px;display:inline-block;margin-left:25px;")
                  label(style="width:auto;margin-right:12px;font-weight:bold;") Seq No
                  input#calseq(style="width:200px;" readonly="readonly")
                  
                div(style="min-width:20px;display:inline-block;margin-left:25px;")
                  a#dg2excel(disabled="disabled")
              
              +panel('center').bg-base-200.noborder(style="padding:8px")
                #dgtests

          +tab-item('Attachments', {iconCls:'icon-pclip'})
            +filegrid#gmfiles(data-options="fit:true")

          +tab-item('User Fields', {iconCls:'icon-list'})
            //+udfs({select:bhave.UDF_LAYOUT_ID,ron:false})
            fieldset(style="margin-top:12px;")
              +fitem('UDF Layout',{id:'UDF_LAYOUT_ID',class:'combobox', name:'UDF_LAYOUT_ID'})
          
            fieldset#udf
              +udf

          +custom('oms')
            +oms_gauge_man_rental()
            
  div.hidden
    #addmenu(style="display:none")
      div(name="GaugeType" data-options="iconCls:'icon-gauge'") GaugeType
        div.no-icon
    
    +dialog#gaugerenameopt(title="Asset Rename" data-options="closed:true,modal:true" style="padding:12px;")
      form#gauge_rename 
        +fitem('Old ID',{id:'RENAME_GAUGE_ID',class:'textbox upper',required:true})
        +fitem('New ID',{id:'NEW_GAUGE_ID',name:'',class:'textbox upper',style:'',required:true, 'data-options':"validType:'length[1,50]'"})
        
        div(style="text-align:center;margin-bottom:0px;margin-top:12px")  
          +button('Rename', {id:'gaugerenamebtn', size:'xs', color:'primary'})
          +button('Cancel', {id:'close', size:'xs', 'data-options':"onClick:function(){$('#gaugerenameopt').dialog('close')}"})
          
          