{
  "id": "enquiry",
  "singleSelect": true,
  "striped": true,
  "rownumbers": true,
  "fitColumns": true,
  "nowrap": true,
  "fit": true,
  "toolbar": "#enquirytb",
  "queryParams": {
    "_func": "get",
    "_sqlid": "dqm^compliance_enquiry",
    "_dgrid": "y"
  },
