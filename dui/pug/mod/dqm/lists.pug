extends ../content 
block script  
  script: include js/lists.js
block style
  style.
    .fitem.inline > label {
      width:125px;
      margin-right:4px;
    }

block content 
  +tabs#lists(data-options="tabPosition:'left', fit:true")
    
    #nng( title='Next Numbers')
      //-include ../nng.inc.pug
        +input({name:'ID', value:'DQM', type:'hidden'})
      form.multi(_sqlid='dqm^nngall', asdpx='ax')
        +fitem('Next Number ID',{id:'NNG_TYPE',name:'TYPE', _sqlid:'dqm^nng' ,required:true, 'data-options':"validType:'length[1,15]'",class:'combobox fkey fit' })
        +fitem('Description',{id:'NNG_DESC',name:'DESCRIPTION', 'data-options':"validType:'length[1,255]'",class:'textbox' })
        +fitem('Prefix',{id:'NNG_PREFIX',name:'PREFIX', 'data-options':"validType:'length[1,8]'",class:'textbox' })
        +fitem('Next Number',{id:'NNG_NEXT',name:'NEXT_NUMBER', precision:0,min:1,class:'numberspinner' })
        
        +fitem('Suffix',{name:'SUFFIX', class:'combobox','data-options':"data:[{text:'None',value:''},{text:'Year 4 Digits',value:'$Y4'},{text:'Year 2 Digits',value:'$Y2'},{text:'Month',value:'$M'},{text:'Month Name',value:'M3'},{text:'-Year 4 Digits',value:'-$Y4'},{text:'-Year 2 Digits',value:'-$Y2'},{text:'-Month',value:'-$M'},{text:'-Month Name',value:'-M3'},{text:'YYMMDD',value:'YYMMDD'},{text:'YYYYMMDD',value:'YYYYMMDD'},{text:'-YYMMDD',value:'-YYMMDD'},{text:'-YYYYMMDD',value:'-YYYYMMDD'}]", default:'$Y4' })
        
        +fitem('Suffix User Defined',{id:'SUFFIX_UDF',name:'SUFFIX_UDF',class:'textbox' ,'data-options':"validType:'length[1,5]'"})
        +fitem('Decimal Digits',{name:'DECIMAL_PLACES',class:'numberspinner' ,value:1,min:1,max:10,precision:0})
        +fitem('Table Name',{id:'TABLE_NAME1', name:'TABLE_NAME', readonly:true, class:'combobox'})
        +fitem('Column Name',{id:'COLUMN_NAME1',name:'COLUMN_NAME', readonly:true, class:'combobox'})  
    #sa_cust(title='Customers')
      form.multi( asdpx='adx',_sqlid='sales^custall')
        div.two
          div(style="width:420px;") 
            +fitem('Customer ID',{name:'ID', _sqlid_:'custid', class:'combobox fkey',validType:['length[1,15]'],required:true})
            +fitem('Name',{name:'NAME', class:'textbox' , validType:['length[1,80]']})
            +fitem('Currency',{name:'CURRENCY_ID', class:'combobox' , _sqlid:'admin^curr',required:true,'data-options':"editable:false"})
            +fitem('GST Code',{name:'GST_ID', class:'combobox' , _sqlid:'admin^gst',required:true,'data-options':"editable:false"})

            +fieldset('Main',{style:'margin-top:12px;'})
              +fitem('Address 1',{name:'ADDR_1', class:'textbox' ,validType:['length[1,50]']})
              +fitem('Address 2',{name:'ADDR_2', class:'textbox' ,validType:['length[1,50]']})
              +fitem('Address 3',{name:'ADDR_3', class:'textbox' ,validType:['length[1,50]']})
            
            +fieldset('COC',{style:'margin-top:12px;'})
              +fitem('Address 1',{name:'COC_ADDR_1', class:'textbox' ,validType:['length[1,50]']})
              +fitem('Address 2',{name:'COC_ADDR_2', class:'textbox' ,validType:['length[1,50]']})
              +fitem('Address 3',{name:'COC_ADDR_3', class:'textbox' ,validType:['length[1,50]']})
              +fitem('Email',{name:'COC_EMAIL', class:'textbox',validType:['email']})
          div
            +fieldset('Contact',{style:'margin-top:12px;'})
              +fitem('Person',{name:'CONTACT_PERSON', class:'textbox',validType:['length[1,80]']})
              +fitem('Phone',{name:'CONTACT_PHONE', class:'textbox',validType:['length[1,80]']})
              +fitem('Fax',{name:'CONTACT_FAX', class:'textbox',validType:['length[1,80]']})
              +fitem('Email',{name:'CONTACT_EMAIL', class:'textbox',validType:['email']})
              +fitem('Subscribe To Events',{name:'SUBSCRIBE_EVENT', class:'combobox','data-options':"data:[{text:'YES',value:'Y'},{text:'NO',value:'N', selected:true}],editable:false"})
            
            +fieldset('Bill-To',{style:'margin-top:12px;'})
              +fitem('Person',{name:'BILL_TO_PERSON', class:'textbox',validType:['length[1,80]']})
              +fitem('Phone',{name:'BILL_TO_PHONE', class:'textbox',validType:['length[1,80]']})
              +fitem('Fax',{name:'BILL_TO_FAX', class:'textbox',validType:['length[1,80]']})
              +fitem('Email',{name:'BILL_TO_EMAIL', class:'textbox',validType:['email']})
    
    #sa_vendor(title='Vendors') 
      form.multi(_sqlid='inv^vendorall', asdpx='adx')
        +fitem('Vendor ID',{name:'ID', _sqlid_:'vendorid', class:'combobox fkey',validType:['length[1,15]'],required:true})
        +fitem('Name',{name:'NAME', class:'textbox' , validType:['length[1,50]']})
        +fitem('Currency',{name:'CURRENCY_ID', class:'combobox' , _sqlid:'admin^curr',required:true,'data-options':"editable:false"})
        +fitem('GST Code',{name:'GST_ID', class:'combobox' , _sqlid:'admin^gst',required:true,'data-options':"editable:false"})

        +fieldset('Main',{style:'margin-top:12px;'})
          +fitem('Address 1',{name:'ADDR_1', class:'textbox' ,validType:['length[1,50]']})
          +fitem('Address 2',{name:'ADDR_2', class:'textbox' ,validType:['length[1,50]']})
          +fitem('Address 3',{name:'ADDR_3', class:'textbox' ,validType:['length[1,50]']})
        
        +fieldset('Contact',{style:'margin-top:12px;'})
          +fitem('Person',{name:'CONTACT_PERSON', class:'textbox' ,validType:['length[1,80]']})
          +fitem('Phone',{name:'CONTACT_PHONE', class:'textbox' ,validType:['length[1,80]']})
          +fitem('Fax',{name:'CONTACT_FAX', class:'textbox' ,validType:['length[1,80]']})
          +fitem('Email',{name:'CONTACT_EMAIL', class:'textbox' ,validType:['email']})
    
    
    #gaugestatus(title='Gauge Status')
      form.multi(_sqlid='dqm^gaugestatus' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit',name:'ID', _sqlid_:'gaugestatusid' ,required:true, 'data-options':"validType:'length[1,15]'" })
        +fitem('Description',{class:'textbox',name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" }) 

        +fieldset('Gauge In-Out',{style:"margin-top:12px;"})
          +fitem('Allow IN',{class:'combobox',name:'INV_IN', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]" })
          +fitem('Allow OUT',{class:'combobox',name:'INV_OUT', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]"})

        +fieldset('Check In-Out',{style:"margin-top:12px;"})
          +fitem('Allow IN',{class:'combobox',name:'CHECK_IN', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]" })
          +fitem('Allow OUT',{class:'combobox',name:'CHECK_OUT', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]"})
        +fieldset('Calibrate')
          +fitem('Allow IN',{class:'combobox',name:'CALIBRATE_IN', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]" })
          +fitem('Allow OUT',{class:'combobox',name:'CALIBRATE_OUT', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]"})
        +fieldset('Repair')
          +fitem('Allow IN',{class:'combobox',name:'REPAIR_IN', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]" })
          +fitem('Allow OUT',{class:'combobox',name:'REPAIR_OUT', 'data-options':"data:[{text:'No', value:'N'},{text:'Yes', value:'Y', selected:true}]"})      
    
    #gaugetype(title='Gauge Types')
      form.multi(_sqlid='dqm^GTNNG' asdpx='ax' data-lbut="ax" data-ebut="ax")
        fieldset
          +fitem('Gauge Type',{class:'combobox fkey fit',name:'ID' ,_sqlid_:'gaugeType' ,required:true, 'data-options':"validType:'length[1,15]'" })
          +fitem('Description',{id:'DESCRIPTION',class:'textbox',name:'DESCRIPTION' ,'data-options':"validType:['length[1,255]']" })
        +fieldset('Next Number')
          +fitem('Prefix',{name:'PREFIX', 'data-options':"validType:'length[1,8]'",class:'textbox' })
          +fitem('Next Number',{name:'NEXT_NUMBER', precision:0,min:1,class:'numberspinner' })
          +fitem('Suffix',{name:'SUFFIX', class:'combobox','data-options':"data:[{text:'None',value:''},{text:'Year 4 Digits',value:'$Y4'},{text:'Year 2 Digits',value:'$Y2'},{text:'Month',value:'$M'},{text:'Month Name',value:'M3'},{text:'-Year 4 Digits',value:'-$Y4'},{text:'-Year 2 Digits',value:'-$Y2'},{text:'-Month',value:'-$M'},{text:'-Month Name',value:'-M3'},{text:'YYMMDD',value:'YYMMDD'},{text:'YYYYMMDD',value:'YYYYMMDD'},{text:'-YYMMDD',value:'-YYMMDD'},{text:'-YYYYMMDD',value:'-YYYYMMDD'}]", default:'$Y4' })
          +fitem('Decimal Digits',{name:'DECIMAL_PLACES',class:'numberspinner' ,value:1,min:1,max:5,precision:0})
          +fitem('Table Name',{id:'TABLE_NAME2',name:'TABLE_NAME' ,readonly:true})
          +fitem('Column Name',{id:'COLUMN_NAME2',name:'COLUMN_NAME', readonly:true, class:'combobox'})
    
    #units(title='Units of Measure')
      form.multi(_sqlid='inv^unitsall' asdpx='ax')
        +fitem('UOM ID',{name:'ID', _sqlid_:'unitsid', class:'combobox fkey fit',validType:['length[1,15]'],required:true})
        +fitem('Description',{name:'DESCRIPTION', class:'textbox',validType:['length[1,30]']})
    
    #sa_deviation(title='Deviation Codes')
      form.multi(_sqlid='vwltsa^devall' asdpx='ax')
        +fitem('Deviation ID',{name:'ID', _sqlid_:'devid', class:'combobox fkey fit',validType:['length[1,15]'],required:true})
        +fitem('Description',{name:'DESCRIPTION', class:'textbox' ,validType:['length[1,80]']})
    
    #cfcause(title='CF Cause Codes')
      form.multi(_sqlid='dqm^cfcauses' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit',name:'ID' ,_sqlid_:'cfcause' ,'data-options':"formatter: cbocols, widths:['20%','80%'], validType:['length[1,15]'] ", required:true })
        +fitem('Description',{class:'textbox',name:'DESCRIPTION' ,'data-options':"multiline:true, validType:'length[1,255]'" ,style:"height:60px;" })
        +fitem('Class ID',{class:'combobox',name:'CLASS_ID' ,_sqlid_:'causeclassid' ,required:true, 'data-options':"validType:'length[1,15]'" })  
    
    #ci_type(title='CI Types')
      form.multi(_sqlid='dqm^ci_types' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit',name:'ID' ,_sqlid_:'ci_type' ,required:true})
        +fitem('Description',{class:'textbox' ,name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" })
        +fitem('Class ID',{class:'combobox', name:'TYPE' ,'data-options':"data:[{text:'CF',value:'CF'},{text:'CPAR',value:'CPAR'},{text:'NCR',value:'NCR'},{text:'OTHER',value:'OTHER', 'selected':true}]" ,required:true})
    
    #ci_cause(title='CI Cause Codes')
      form.multi(_sqlid='dqm^cicauses' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit' ,name:'ID', _sqlid_:'cicause' ,'data-options':"formatter: cbocols, widths:['20%','80%'], validType:['length[1,15]']" , required:true })
        +fitem('Description',{class:'textbox' ,name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" })
        +fitem('Class ID',{class:'combobox', name:'CLASS_ID' ,_sqlid_:'causeclassid', required:true, 'data-options':"validType:'length[1,15]'" })
    
    #cparcause(title='CPAR Cause Codes')
      form.multi(_sqlid='dqm^cparcauses' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit' ,name:'ID', _sqlid_:'cparcause' ,'data-options':"formatter: cbocols, widths:['20%','80%'], validType:['length[1,15]']" , required:true  })
        +fitem('Description',{class:'textbox' ,name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" })
        +fitem('Class ID',{class:'combobox', name:'CLASS_ID' ,_sqlid_:'causeclassid', required:true, 'data-options':"validType:'length[1,15]'" })
    
    #cause(title='NCR Cause Codes')
      form.multi(_sqlid='dqm^causes' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit' ,name:'ID', _sqlid_:'cause' ,'data-options':"formatter: cbocols, widths:['20%','80%'], validType:['length[1,15]']" , required:true })
        +fitem('Description',{class:'textbox' ,name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" })
        +fitem('Class ID',{class:'combobox', name:'CLASS_ID' ,_sqlid_:'causeclassid', required:true, 'data-options':"validType:'length[1,15]'" })

    #otd(title='OTD Cause Codes')
      form.multi(_sqlid='dqm^otdcauses' asdpx='ax')
        +fitem('ID',{class:'combobox fkey fit' ,name:'ID', _sqlid_:'otdcause' ,'data-options':"formatter: cbocols, widths:['20%','80%'], validType:['length[1,15]']" , required:true })
        +fitem('Description',{class:'textbox' ,name:'DESCRIPTION' ,'data-options':"validType:'length[1,255]'" })
        //-+fitem('Class ID',{class:'combobox', name:'CLASS_ID' ,_sqlid_:'causeclassid', required:true, 'data-options':"validType:'length[1,15]'" })
    
    #sa_department(title='Certification')
      form.multi(_sqlid='dqm^modulesall', asdpx='ax')
        +fitem('Module ID',{class:'combobox fkey fit',name:'ID', _sqlid_:'moduleid' ,'data-options':"validType:'length[1,15]'" ,required:true})
        +fitem('Module Class',{class:'combobox',name:'TYPE' ,_sqlid_:'moduletypeid'  ,required:true})
        +fitem('Description',{class:'textbox', name:'DESCRIPTION' ,'data-options':"validType:'length[1,80]',multiline:true" ,style:"height:75px;"})

    #sa_qualifications(title='Qualification')
      form.multi(_sqlid='dqm^qualificationsall', asdpx='ax')
        +fitem('Qualification ID',{class:'combobox fkey fit',name:'ID', _sqlid_:'qualificationid' ,'data-options':"validType:'length[1,30]'" ,required:true})
        +fitem('Description',{class:'textbox', name:'DESCRIPTION' ,'data-options':"validType:'length[1,80]',multiline:true" ,style:"height:75px;"})

    #cocspec(title='COC Boiler Plates')
      form.multi(_sqlid='dqm^coc_boilerplates' asdpx='ax').fit
        +hsplit('170px').no-border
          +panel('north', { style: "padding:6px;" })

            +fitem('ID',{class:'combobox fkey fit',name:'ID' ,_sqlid_:'coc_boilerplate' ,required:true, 'data-options':"validType:'length[1,15]'"})

            +fitem('Type',{class:'combobox', name:'TYPE', required:true, 'data-options':"data:[{text:'Patents',value:'PATENT'},{text:'Conformance',value:'CONFORM'},{text:'Warranty',value:'WARRANTY'}]"})

            +fitem('Default',{class:'combobox',required:true, name:'DEFAULT_VAL', 'data-options':"data:[{text:'No', value:'N',selected:true},{text:'Yes', value:'Y'}]"})

            +fitem('Revision',{class:'numberspinner',name:'REV' ,value:"1" ,min:"1" ,precision:"0"  })

          +panel('center', { style: "padding:6px;" })
            label(style="margin-left:20px;") Specifications
            div(style="margin-left:165px;height:98%;margin-top:-16px;")
              +textbox(name='DESCRIPTION' data-options="multiline:true" style="height:100%; width:100%;" )
    
    +custom('oms') 
      +oms_lists_rental()  