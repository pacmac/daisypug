                +fitem('Type',{name:'CBO_APP_PRIMER_TYPE', class:'combobox edit first'})
              +fieldset('Top Coat')
                +fitem('Manufacturer',{name:'CBO_APP_COAT_MFG', class:'combobox edit first'})
                +fitem('Type',{name:'CBO_APP_COAT_TYPE', class:'combobox edit first'})

