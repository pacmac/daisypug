          +fitem('Require Doc Ref',{name:'reqdoc', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})

    +tab-item('Test Plans',{iconCls:"aicon-org"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^qp^qp_qpman")
        +fieldset('Misc Settings')
          +fitem('Part Type',{name:'partType', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'Part',value:'PART',selected:true},{text:'Job',value:'WORK_ORDER'}]"})
        +fieldset('Last Selection Memory')
          +fitem('Title',{name:'MEM_TITLE', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Doc Ref',{name:'MEM_DOC', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Doc Grid-Ref',{name:'MEM_GREF', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
        +fieldset('Repair/Calibration')
          +fitem('Require Vendor',{name:'reqven', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Require Doc Ref',{name:'reqdoc', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})

    +tab-item('Resin Coating',{iconCls:"icon-coat-resin"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')#coatman
        input(type="hidden" name="appid" value="dqm^qtr^qp_coatman")
        div.two
          div
            +fieldset('Misc Settings')
              +fitem('Job Class',{name:'JOB_CLASS', class:'textbox', value:'DEFAULT'})
              +fitem('Lock Completed',{name:'COMPLETE_LOCK', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
            +fieldset('Main Lists')
              +fitem('Coating Colour',{name:'CBO_COAT_COLOUR', class:'combobox edit first'})
              +fitem('Coating Spec ID',{name:'CBO_COAT_SPEC_ID', class:'combobox edit first'})
              +fitem('Quality Spec',{name:'CBO_QA_SPEC_ID', class:'combobox edit first'})
            +fieldset('Surface Prep Lists')
              +fitem('Solvent Type',{name:'CBO_SURF_SOLV_TYPE', class:'combobox edit first'})
              +fitem('Blast/Grit Type',{name:'CBO_SURF_BLAST_TYPE', class:'combobox edit first'})
          div
            +fieldset('Application Lists')
              +fieldset('Phosphate')
                +fitem('Manufacturer',{name:'CBO_APP_PHOS_MFG', class:'combobox edit first'})
                +fitem('Type',{name:'CBO_APP_PHOS_TYPE', class:'combobox edit first'})
                +fitem('Colour',{name:'CBO_APP_PHOS_COLOUR', class:'combobox edit first'})
              +fieldset('Primer')
