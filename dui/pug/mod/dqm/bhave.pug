extends ../content
block script
  script: include js/bhave.js

block content
  mixin usercombo(label,name)
    +fitem(label,{name:name, id:name, class:'combobox user-combo', _sqlid:'dqm^cbo_uid'})
      input(name=name+'_EMAIL' type="hidden" id=name+'_EMAIL')

  +tabs#bhtabs(data-options="tabPosition:'left'")

    +tab-item('CAAS(AW)95',{iconCls:"icon-awe95"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')#caas_aw95
        input(type="hidden" name="appid" value="dqm^caas_aw95")
        +fieldset('Combo Items')
          +fitem('Work Status',{name:'CBO_STATUS_WORK', class:'combobox edit first'})

    +tab-item('COC',{iconCls:"icon-coc"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^coc_man")
        +fieldset('NCRs')
          +fitem('Allow Open NCRs',{name:'ALLOW_NCR', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
        +fieldset('COC Resource')
          +fitem('Allow lower Completed qty in prior opnr',{name:'ALLOW_OPEN_OPN', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Allow Unissued Material',{name:'ALLOW_OPN_PART', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Resource ID',{name:'COC_RESOURCE', class:'combobox', 'data-options':"panelHeight:'auto'", _sqlid:'vwltsa^resid'})
          +fitem('Ignored Resources',{name:'COC_IGNORED_RESOURCES', class:'textbox', 'data-options':"multiline:true", style:'height:200px;'})
        +fieldset('User Labels')
          -for (var x=1; x<6; x++)
            +fitem('User Label '+x,{name:'ulabel_'+x, class:'textbox'})

    +tab-item('NCR',{iconCls:"icon-ncr"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^comp^ncr_man")
        +fieldset('Combo Items')
          +fitem('Material Disposition',{name:'DISPOSITION_MATERIAL', class:'dispomat combobox edit'})
        +fieldset('Auto-Created NCR')
          +fitem('Job Ticket Deviated Qty',{name:'newncr_jobticket_badqty', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +usercombo('Default Reported By','newncr_jobticket_reportedby')
        +fieldset('Link Source')
          +fitem('Enforce Valid Job',{name:'enforce_valid_job', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})

    +tab-item('CPAR',{iconCls:"icon-cpar"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^comp^cpar_man")
        +fieldset('Combo Items')
          +fitem('Material Disposition',{name:'DISPOSITION_MATERIAL', class:'dispomat combobox edit'})
        +fieldset('Auto-Created CPAR')
          +fitem('Followup NCR',{name:'newcpar_ncr_followup', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Followup CF',{name:'newcpar_cf_followup', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
          +fitem('Enabled Liability Cost',{name:'CPAR_DISPOSITION_LIABILITY_COST', class:'textbox', 'data-options':"multiline:true", style:'height:200px;'})

    +tab-item('CF',{iconCls:"icon-cf"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^comp^cf_man")
        +fieldset('Combo Items')
          +fitem('Material Disposition',{name:'DISPOSITION_MATERIAL', class:'dispomat combobox edit'})

    +tab-item('Operators',{iconCls:"icon-user"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^opcert^operators")
        +fieldset('General')
          +fitem('Default UDF',{class:'combobox', name:'defudf', 'data-options':"panelHeight:'auto'", _sqlid:'vwltsa^udfid'})
        +fieldset('Tab Access')
          +fitem('User Fields',{name:'udfen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('Resources',{name:'resen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('Certification',{name:'certen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('Qualifications',{name:'qualen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('NCRs',{name:'ncren', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('Attachments',{name:'docen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})
          +fitem('Rating',{name:'rating', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n'},{text:'Yes',value:'y',selected:true}]"})

    +tab-item('Analysis',{iconCls:"icon-chart"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^comp^analysis")
        +fitem('Start Date',{name:'frdate', class:'datebox year'})
        +fieldset('Defect Labels')
          +fitem('No Code Label',{name:'nonetext', value:'No Code', class:'textbox upper'})
          +fitem('Total Label',{name:'alltext', value:'ALL-DEFECTS', class:'textbox upper'})
          +fitem('Top N Defects',{name:'top', value:3, precision:0, min:1, class:'numberspinner'})
        +fieldset('Report-NCR')
          +fitem('Cost',{name:'NCRCOST', value:500, precision:2, min:100, class:'numberspinner'})
        +fieldset('Report-KPI')
          +fitem('Avg Quote Time',{name:'AVG', value:3, precision:0, min:1, class:'numberspinner'})
          +fitem('Operating Cost',{name:'OPERATING_COST', value:20000, precision:0, min:1, class:'numberspinner'})
          +fitem('MR Folder',{name:'MR_FOLDER', class:'textbox'})

    +tab-item('Gauge Manager',{iconCls:"icon-gauge"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')#gaugeman
        input(type="hidden" name="appid" value="dqm^gauges^gauge_man")
        +fieldset('Misc Settings')
          +fitem('Gauge Numbering',{name:'autonum', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'Auto',value:'AUTO',selected:true},{text:'Manual',value:'USER'}]"})
          +fitem('Allow Gauge Rename',{name:'allow_gauge_rename', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'Yes',value:'y'},{text:'No',value:'n',selected:true}]"})
          +fitem('Show Due Alert',{name:'duealert', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'Yes',value:'y',selected:true},{text:'No',value:'n'}]"})
          +fitem('Due Alert Days',{name:'alertdays', value:'7', class:'numberspinner', precision:0})
          +fitem('Outside Diameter',{name:'CBO_OUTSIDE_DIAMETER', class:'combobox edit first', 'data-options':"panelHeight:'auto'"})
        +fieldset('Initial Calibration')
          +fitem('Calibration #1',{name:'caldays1', value:'60', precision:0, class:'numberspinner'})
          +fitem('Calibration #2',{name:'caldays2', value:'120', precision:0, class:'numberspinner'})

    +tab-item('Gauge Trans',{iconCls:"icon-inout"})
      form.single.load(_sqlid='admin^bhave' asdpx='s')
        input(type="hidden" name="appid" value="dqm^gauges^gauge_inv")
        +fieldset('Appearance')
          +fitem('Hide Menu',{name:'fscreen', class:'combobox', 'data-options':"panelHeight:'auto', data:[{text:'No',value:'n',selected:true},{text:'Yes',value:'y'}]"})
