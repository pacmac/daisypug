doctype html
html(lang="en" data-theme="light")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Error
    link(href="/assets/css/main.css" rel="stylesheet" type="text/css")
    script(src="https://code.jquery.com/jquery-3.7.1.min.js")
    style.
      body {
        min-height: 100vh;
        background: radial-gradient(circle at top, rgba(255, 255, 255, 0.9), rgba(226, 232, 240, 0.9));
        margin: 0;

      }
      main {
        max-width: 960px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 4rem;
      }

  body
    main
      .hero.min-h-screen.bg-base-200
        .hero-content.text-center
          .max-w-2xl
            h1.text-5xl.font-bold.text-error Error
            p.py-6 Something went wrong while rendering the page.
            
            .mockup-code.bg-neutral.text-neutral-content.text-left
              pre.px-4.py-2
                code#errors= error
            
            .mt-6
              a.btn.btn-primary(href="/") Go Home
