extends ./layout.pug

//- Dashboard Layout
//- Extends base layout with DaisyUI navbar (topnav) + drawer (left nav) + content area
//- Full width/height viewport coverage using DaisyUI patterns
//- Uses classic Pug extends/block model - NOT a mixin (not reused)
//- Purpose: Provide foundation for all dashboard pages (admin, production, inventory, etc.)

block content
  - const drawer_id = 'dashboard-drawer'
  
  style.
    main { max-width: 100% !important; padding: 0 !important; margin: 0 !important; }
  
  //- Drawer structure (DaisyUI drawer component) - full screen
  //- Following DaisyUI pattern: drawer > (drawer-toggle, drawer-content + navbar, drawer-side + menu)
  .drawer.h-screen
    input.drawer-toggle(type="checkbox" id=drawer_id + "-toggle")
    
    //- DRAWER CONTENT: Flex column with navbar (flex-none) and content (flex-1 overflow)
    .drawer-content.flex.flex-col.h-screen
      
      //- Navbar (Topnav) - flex-none so it doesn't scroll, w-full to span full width
      nav.navbar.bg-base-100.shadow-sm.w-full.flex-none
        .navbar-start
          //- Hamburger menu button (toggle drawer)
          label.btn.btn-ghost.drawer-button(for=drawer_id + "-toggle")
            svg.w-6.h-6(fill="none" stroke="currentColor" viewBox="0 0 24 24")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16")
        
        .navbar-end
          a.btn.btn-ghost.normal-case= 'Pure4'
        
        //- commented by PAC
          .navbar-end
            span= userid ? userid.toUpperCase() : '?'


      //- Main content area (flex-1 takes remaining space, overflow-auto for scrolling)
      .flex-1.overflow-auto.bg-base-200
        div.page-wrapper.flex.flex-col.min-h-full
          if pageContent
            != pageContent
          else
            block page-content

      //- Footer (static, half height of navbar - navbar is typically h-16/64px, so footer is h-8/32px)
      footer.bg-base-300.border-t.border-base-300.px-4.py-2.flex-none.h-8.flex.items-center.text-base-content.opacity-75
        span &copy; #{new Date().getFullYear()} DiGiTaL Information Systems Pte Ltd

    //- DRAWER SIDE (Left navigation panel)
    //- Following DaisyUI pattern: drawer-side > (drawer-overlay + sidebar content)
    .drawer-side
      label.drawer-overlay(for=drawer_id + "-toggle")
      .bg-base-200.w-64.overflow-auto.min-h-full.px-2.py-4

        //- Menu navigation - #westMenu for tree-based nav (EUI compat)
        nav#westMenu
          if config.menu_render == 'client'
            //- Client-side: templates + empty container (JS builds menu from $.dui.udata.menus)
            template#tpl-menu-group
              li
                details
                  summary
                    span.menu-icon(data-lucide="")
                    span.menu-text
                  ul.menu

            template#tpl-menu-item
              li
                a(href="#" data-page="" data-appid="" data-iconCls="")
                  span.menu-icon(data-lucide="")
                  span.item-text

            ul.menu.bg-base-200.rounded-box.w-full#navmenu
          else
            //- Server-side: Pug-rendered menu (current default)
            ul.menu.bg-base-200.rounded-box.w-full
              each item in udata.menus
                if item && item.text
                  +menuItem(item, true)


