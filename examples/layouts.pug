//- DaisyPug Layout Demo — vsplit/hsplit/panel patterns

+navbar({class: 'bg-primary text-primary-content shadow-lg'})
  +navbar-start
    span.text-xl.font-bold.px-4 Layout Patterns
  +navbar-end
    +theme-radios({themes: ['light', 'dark', 'cupcake', 'synthwave'], as: 'btn', active: 'light'})

div.p-6.max-w-6xl.mx-auto.space-y-8

  //- ===== Pattern 1: Basic Sidebar =====
  h2.text-2xl.font-bold 1. Basic Sidebar
  p.text-sm.opacity-60.mb-2 vsplit('250px') — sidebar + content

  div(style="height: 300px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-vsplit('250px')
      +dp-panel('west', {title: 'Sidebar', iconCls: 'bi bi-list'})
        +menu({class: 'p-2'})
          +menu-title({text: 'Navigation'})
          +menu-item({active: true})
            a Dashboard
          +menu-item
            a Orders
          +menu-item
            a Products
          +menu-item
            a Settings
      +dp-panel('center', {title: 'Main Content'})
        div.p-4
          h3.text-lg.font-semibold Welcome
          p.mt-2.opacity-70 This is the main content area. The sidebar is 250px wide.

  //- ===== Pattern 2: Top + Bottom =====
  h2.text-2xl.font-bold 2. Header + Content
  p.text-sm.opacity-60.mb-2 hsplit('50px') — toolbar + content

  div(style="height: 300px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-hsplit('50px')
      +dp-panel('north', {scroll: false})
        div.flex.items-center.justify-between.px-4.h-full.bg-base-200
          div.flex.items-center.gap-2
            span.font-bold Page Title
          div.flex.gap-1
            +btn({color: 'primary', size: 'sm', text: 'Add'})
            +btn({size: 'sm', text: 'Edit'})
            +btn({color: 'error', size: 'sm', style: 'outline', text: 'Delete'})
      +dp-panel('center')
        div.p-4
          +table({headers: ['ID', 'Name', 'Status'], rows: [['001', 'Widget A', 'Active'], ['002', 'Widget B', 'Draft'], ['003', 'Widget C', 'Active']], zebra: true, size: 'sm'})

  //- ===== Pattern 3: Three Columns =====
  h2.text-2xl.font-bold 3. Three Columns
  p.text-sm.opacity-60.mb-2 Nested vsplit — nav + list + detail

  div(style="height: 350px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-vsplit('180px')
      +dp-panel('west', {title: 'Folders'})
        +menu({size: 'sm', class: 'p-2'})
          +menu-item({active: true})
            a Inbox (3)
          +menu-item
            a Sent
          +menu-item
            a Drafts
          +menu-item
            a Trash
      +dp-vsplit('300px')
        +dp-panel('west', {title: 'Messages'})
          +list({size: 'sm'})
            +list-row
              div
                div.font-semibold.text-sm Alice
                div.text-xs.opacity-60 Meeting tomorrow at 10am
            +list-row
              div
                div.font-semibold.text-sm Bob
                div.text-xs.opacity-60 Updated the report
            +list-row
              div
                div.font-semibold.text-sm Carol
                div.text-xs.opacity-60 Can you review this PR?
        +dp-panel('center', {title: 'Preview'})
          div.p-4
            h3.font-bold Meeting tomorrow at 10am
            div.text-sm.opacity-60.mt-1 From: Alice — Mar 22, 2026
            +divider
            p Let's meet at 10am to discuss the project roadmap. I'll book the meeting room.

  //- ===== Pattern 4: Dashboard Grid =====
  h2.text-2xl.font-bold 4. Dashboard Layout
  p.text-sm.opacity-60.mb-2 hsplit + nested vsplit — toolbar + (sidebar + main)

  div(style="height: 400px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-hsplit('48px')
      +dp-panel('north', {scroll: false})
        div.flex.items-center.px-4.h-full.bg-primary.text-primary-content
          span.font-bold.text-lg DashApp
          div.flex-1
          +btn({style: 'ghost', size: 'sm', text: 'Profile'})
      +dp-vsplit('220px')
        +dp-panel('west')
          +menu({class: 'p-3'})
            +menu-title({text: 'Dashboard'})
            +menu-item({active: true})
              a Overview
            +menu-item
              a Analytics
            +menu-title({text: 'Manage'})
            +menu-item
              a Users
            +menu-item
              a Settings
        +dp-panel('center')
          div.p-4
            +stats({class: 'shadow w-full mb-4'})
              +stat
                +stat-title({text: 'Revenue'})
                +stat-value({text: '$12.4K'})
              +stat
                +stat-title({text: 'Users'})
                +stat-value({text: '2,100'})
              +stat
                +stat-title({text: 'Orders'})
                +stat-value({text: '340'})
            +table({headers: ['Date', 'Customer', 'Amount'], rows: [['Mar 22', 'Acme Corp', '$1,200'], ['Mar 21', 'Globex', '$850'], ['Mar 20', 'Initech', '$2,400']], zebra: true, size: 'sm'})

  //- ===== Pattern 5: IDE Layout =====
  h2.text-2xl.font-bold 5. IDE Layout
  p.text-sm.opacity-60.mb-2 vsplit + hsplit — explorer + (editor + terminal)

  div(style="height: 400px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-vsplit('220px')
      +dp-panel('west', {title: 'Explorer'})
        +menu({size: 'sm', class: 'p-2'})
          +menu-title({text: 'src/'})
          +menu-item
            a index.js
          +menu-item({active: true})
            a engine.js
          +menu-item
            a dp.js
          +menu-title({text: 'mixins/'})
          +menu-item
            a btn.pug
          +menu-item
            a card.pug
          +menu-item
            a tabs.pug
      +dp-hsplit('65%')
        +dp-panel('north', {title: 'engine.js'})
          +mockup-code({class: 'rounded-none h-full', lines: [{prefix: '1', text: "const pug = require('pug');"}, {prefix: '2', text: "const path = require('path');"}, {prefix: '3', text: ''}, {prefix: '4', text: 'function renderPage(content, opts) {'}, {prefix: '5', text: '  const html = pug.render(content);'}, {prefix: '6', text: '  return html;'}, {prefix: '7', text: '}'}]})
        +dp-panel('south', {title: 'Terminal'})
          +mockup-code({class: 'rounded-none h-full', lines: [{prefix: '$', text: 'node test/test-tier1.js'}, {prefix: '>', text: '23 passed, 0 failed'}, {prefix: '$', text: ''}]})

  //- ===== Pattern 6: Master-Detail =====
  h2.text-2xl.font-bold 6. Master-Detail (Horizontal)
  p.text-sm.opacity-60.mb-2 hsplit('55%') — grid on top + form below

  div(style="height: 380px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-hsplit('55%')
      +dp-panel('north', {title: 'Parts List'})
        div.p-2
          +table({headers: ['Part ID', 'Description', 'Qty', 'Price'], rows: [['P-001', 'Bearing 6205', '120', '$4.50'], ['P-002', 'O-Ring Kit', '45', '$12.00'], ['P-003', 'Drive Belt', '8', '$28.50']], zebra: true, size: 'sm'})
      +dp-panel('south', {title: 'Part Details'})
        div.p-4
          +fieldset
            +fieldset-legend({text: 'Edit Part'})
            div(class="grid grid-cols-2 gap-x-4 gap-y-2")
              +dp-fitem('Part ID', {class: 'textbox', name: 'PART_ID', id: '~', value: 'P-001'})
              +dp-fitem('Description', {class: 'textbox', name: 'DESC', id: '~', value: 'Bearing 6205'})
              +dp-fitem('Quantity', {class: 'numberspinner', name: 'QTY', id: '~', value: '120', min: 0, precision: 0})
              +dp-fitem('Price', {class: 'numberbox', name: 'PRICE', id: '~', value: '4.50', precision: 2})

  //- ===== Pattern 7: DUI-style Form =====
  h2.text-2xl.font-bold 7. DUI-style Form (fitem auto-detect)
  p.text-sm.opacity-60.mb-2 +dp-fitem auto-detects input type from class — 3-column layout

  div(style="border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden; padding: 1rem;")
    +dp-form({id: 'fitem-demo'}).three
      .divider.text-xs.font-bold.opacity-50.mt-0(style="grid-column:1/-1") DETAILS
      +dp-fitem('Part ID', {class: 'combobox', name: 'PART_ID', id: '~', options: ['A8000 - Pump', 'B3200 - Bearing', 'C1500 - Valve']})
      +dp-fitem('Description', {class: 'textbox', name: 'DESCRIPTION', id: '~', placeholder: 'Enter description'})
      +dp-fitem('Status', {class: 'combobox', name: 'STATUS', id: '~', options: [{value: 'A', text: 'Active'}, {value: 'I', text: 'Inactive'}]})

      .divider.text-xs.font-bold.opacity-50(style="grid-column:1/-1") QUANTITIES
      +dp-fitem('Quantity', {class: 'numberspinner', name: 'QTY', id: '~', min: 0, precision: 0, value: '25'})
      +dp-fitem('Weight (kg)', {class: 'numberbox', name: 'WEIGHT', id: '~', precision: 2, value: '12.50'})
      +dp-fitem('Unit Price', {class: 'numberbox', name: 'PRICE', id: '~', precision: 2, value: '199.99'})

      .divider.text-xs.font-bold.opacity-50(style="grid-column:1/-1") DATES
      +dp-fitem('Order Date', {class: 'datebox', name: 'ORDER_DATE', id: '~'})
      +dp-fitem('Due Date', {class: 'datebox', name: 'DUE_DATE', id: '~'})
      +dp-fitem('Password', {class: 'passwordbox', name: 'PASS', id: '~', placeholder: 'secret'})

      .divider.text-xs.font-bold.opacity-50(style="grid-column:1/-1") OTHER
      +dp-fitem('Active', {class: 'checkbox', name: 'ACTIVE', id: '~', checked: true})
      +dp-fitem('Notify', {class: 'toggle', name: 'NOTIFY', id: '~'})
      +dp-fitem('Attachment', {class: 'filebox', name: 'ATTACH', id: '~'})

      div(style="grid-column:1/-1")
        +dp-fitem('Notes', {class: 'multiline', name: 'NOTES', id: '~', rows: 3, placeholder: 'Additional notes...'})

  //- ===== Pattern 8: Form with Groups =====
  h2.text-2xl.font-bold 8. Form with Groups
  p.text-sm.opacity-60.mb-2 +dp-group for vertical sections, +dp-hgroup for side-by-side fields

  div(style="border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden; padding: 1rem; max-width: 500px;")
    +dp-form({id: 'group-demo'})
      +dp-fitem('Part ID', {class: 'combobox', name: 'PART_ID', id: '~', options: ['A8000', 'B3200']})
      +dp-fitem('Description', {class: 'textbox', name: 'DESCRIPTION', id: '~'})
      +dp-group('Dimensions')
        +dp-fitem('Width', {class: 'numberbox', name: 'WIDTH', id: '~', precision: 2})
        +dp-fitem('Height', {class: 'numberbox', name: 'HEIGHT', id: '~', precision: 2})
        +dp-fitem('Weight', {class: 'numberbox', name: 'WEIGHT', id: '~', precision: 3})
      +dp-group('Financials')
        +dp-fitem('Unit Cost', {class: 'numberbox', name: 'COST', id: '~', precision: 2})
        +dp-fitem('Currency', {class: 'combobox', name: 'CURRENCY', id: '~', options: ['SGD', 'USD', 'EUR']})
      +dp-hgroup('Rates')
        +dp-fitem('Base Rate', {class: 'numberbox', name: 'BASE_RATE', id: '~', precision: 4})
        +dp-fitem('Tax Rate %', {class: 'numberbox', name: 'TAX_RATE', id: '~', precision: 1})

  //- ===== Pattern 9: Toolbar Variants =====
  h2.text-2xl.font-bold 9. Toolbar Variants
  p.text-sm.opacity-60.mb-2 +dp-toolbar with asdpx shorthand, title, icon, separator, custom buttons

  div.space-y-2(style="border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    //- Title + CRUD
    +dp-toolbar({title: 'Parts List', icon: 'bi bi-box-seam', asdpx: 'aed'})

    //- Title + CRUD + custom buttons with separator
    +dp-toolbar({title: 'BOM Lines', icon: 'bi bi-layers', asdpx: 'aed'})
      +dp-toolbar-sep
      +btn({size: 'xs', style: 'ghost', text: 'Validate'})
      +btn({size: 'xs', style: 'ghost', text: 'Export'})

    //- Form CRUD buttons (add/save/delete/cancel)
    +dp-toolbar({title: 'Order Entry', icon: 'bi bi-cart', asdpx: 'asdx'})

    //- No title, just buttons
    +dp-toolbar
      +btn({size: 'xs', style: 'ghost', text: 'Refresh'})
      +dp-toolbar-sep
      +btn({size: 'xs', style: 'ghost', text: 'Export'})

  //- ===== Pattern 10: Full App Page =====
  h2.text-2xl.font-bold 10. Full App Page (Everything Combined)
  p.text-sm.opacity-60.mb-2 vsplit + toolbar + fitem form + datatable — a real CRUD page

  div(style="height: 500px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
    +dp-vsplit('350px')
      +dp-panel('west')
        +dp-toolbar({title: 'Part', icon: 'bi bi-search', asdpx: 'asdx'})
        div.p-3
          +dp-form({id: 'part-form'})
            +dp-fitem('Part ID', {class: 'combobox', name: 'PART_ID', id: '~', options: ['A8000 - Pump', 'B3200 - Bearing', 'C1500 - Valve']})
            +dp-fitem('Description', {class: 'textbox', name: 'DESCRIPTION', id: '~'})
            +dp-group('Dimensions')
              +dp-fitem('Width', {class: 'numberbox', name: 'WIDTH', id: '~', precision: 2})
              +dp-fitem('Height', {class: 'numberbox', name: 'HEIGHT', id: '~', precision: 2})
            +dp-group('Financials')
              +dp-fitem('Cost', {class: 'numberbox', name: 'COST', id: '~', precision: 2})
              +dp-fitem('Currency', {class: 'combobox', name: 'CURRENCY', id: '~', options: ['SGD', 'USD']})
            +dp-fitem('Active', {class: 'checkbox', name: 'ACTIVE', id: '~', checked: true})
      +dp-panel('center')
        +dp-toolbar({title: 'Stock Balances', icon: 'bi bi-list-ul', asdpx: 'aed'})
        div.p-2
          +table({headers: ['Location', 'On Hand', 'Reserved', 'Available'], rows: [['Main Store', '120', '15', '105'], ['Sub Store', '45', '0', '45'], ['Yard', '8', '2', '6']], zebra: true, size: 'sm'})
