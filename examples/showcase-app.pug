//- DaisyPug Component Showcase — dashboard layout, no body scroll

//- Full viewport container
div.flex.flex-col.h-screen.overflow-hidden

  //- Top toolbar (shrink-0)
  +dp-toolbar({title: 'DaisyPug Showcase', icon: 'layout-grid'})
    +dp-toolbar-sep
    +theme-radios({themes: ['light', 'dark', 'cupcake', 'synthwave'], as: 'btn', active: 'light'})

  //- Tabs fill remaining height
  div.flex-1.min-h-0.overflow-hidden
    +tabs({style: 'lift', size: 'lg'})

      //- ===== TAB: Layouts =====
      +tab({name: 'showcase', label: 'Layouts', active: true})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        h3.font-semibold.mb-2 Basic Sidebar — vsplit('250px')
        div(style="height: 250px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
          +dp-vsplit('250px')
            +dp-panel('west', {title: 'Sidebar', iconCls: 'menu'})
              +menu({size: 'sm'})
                +menu-item({active: true})
                  a Dashboard
                +menu-item
                  a Orders
                +menu-item
                  a Settings
            +dp-panel('center', {title: 'Content'})
              div.p-4
                p Main content area. Sidebar is 250px.

        h3.font-semibold.mt-6.mb-2 Nested 3-Column
        div(style="height: 250px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
          +dp-vsplit('150px')
            +dp-panel('west', {title: 'Nav'})
              +menu({size: 'sm'})
                +menu-item({active: true})
                  a Inbox
                +menu-item
                  a Sent
            +dp-vsplit('280px')
              +dp-panel('west', {title: 'List'})
                +list({size: 'sm'})
                  +list-row
                    div.text-sm Meeting at 10am
                  +list-row
                    div.text-sm Updated report
              +dp-panel('center', {title: 'Detail'})
                div.p-4.text-sm Preview content here

        h3.font-semibold.mt-6.mb-2 IDE Layout — vsplit + hsplit
        div(style="height: 280px; border: 1px solid oklch(var(--bc)/.2); border-radius: 0.5rem; overflow: hidden;")
          +dp-vsplit('200px')
            +dp-panel('west', {title: 'Explorer'})
              +menu({size: 'sm'})
                +menu-item
                  a index.js
                +menu-item({active: true})
                  a engine.js
                +menu-item
                  a dp.js
            +dp-hsplit('65%')
              +dp-panel('north', {title: 'editor.js'})
                +mockup-code({class: 'rounded-none h-full text-sm', lines: [{prefix: '1', text: "const pug = require('pug');"}, {prefix: '2', text: 'function render() {'}, {prefix: '3', text: '  return html;'}, {prefix: '4', text: '}'}]})
              +dp-panel('south', {title: 'Terminal'})
                +mockup-code({class: 'rounded-none h-full text-sm', lines: [{prefix: '$', text: 'npm test'}, {prefix: '>', text: '23 passed'}]})

      //- ===== TAB: Forms =====
      +tab({name: 'showcase', label: 'Forms'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        //- ---- CRUD Form with State Machine ----
        h3.font-semibold.mb-2 CRUD Form with State Machine
        div.bg-base-100.rounded-lg.overflow-hidden.mb-6
          +dp-toolbar({id: 'crud_toolbar', title: 'Part Master', icon: 'package', asdpx: 'asdx'})
          div.p-4
            +dp-form({id: 'crud_form'})
              +dp-fitem('Part ID', {class: 'combobox', name: 'CRUD_PART', id: '~', pre: 'package', options: ['A8000 - Pump', 'B3200 - Bearing', 'C1500 - Valve']})
              +dp-fitem('Description', {class: 'textbox', name: 'CRUD_DESC', id: '~', placeholder: 'Part description'})
              +dp-fitem('Price', {class: 'numberbox', name: 'CRUD_PRICE', id: '~', precision: 2, pre: 'dollar-sign'})
            div.mt-2.text-xs.opacity-50
              | Mode:
              span#crud_mode_display view
              |  | Dirty:
              span#crud_dirty_display false

        //- ---- Form-Parts (Multi-Tab) ----
        h3.font-semibold.mb-2 Form-Parts — Single Form Across Tabs
        div.bg-base-100.rounded-lg.overflow-hidden.mb-6
          +dp-toolbar({id: 'parts_toolbar', title: 'Product', icon: 'box', asdpx: 'asdx'})
          div.p-4
            +dp-form({id: 'parts_form'})
              +dp-fitem('Product ID', {class: 'textbox', name: 'PROD_ID', id: '~', pre: 'hash'})
              +dp-fitem('Name', {class: 'textbox', name: 'PROD_NAME', id: '~'})
            +tabs({style: 'box', class: 'mt-3'})
              +tab({name: 'parts-tabs', label: 'Dimensions', active: true})
              +tab-content({class: 'p-3'})
                +dp-form({id: 'parts_form'})
                  +dp-fitem('Width', {class: 'numberbox', name: 'PROD_W', id: '~', precision: 2})
                  +dp-fitem('Height', {class: 'numberbox', name: 'PROD_H', id: '~', precision: 2})
                  +dp-fitem('Weight', {class: 'numberbox', name: 'PROD_WT', id: '~', precision: 3})
              +tab({name: 'parts-tabs', label: 'Financial'})
              +tab-content({class: 'p-3'})
                +dp-form({id: 'parts_form'})
                  +dp-fitem('Cost', {class: 'numberbox', name: 'PROD_COST', id: '~', precision: 2, pre: 'dollar-sign'})
                  +dp-fitem('Currency', {class: 'combobox', name: 'PROD_CUR', id: '~', options: ['SGD', 'USD', 'EUR']})
              +tab({name: 'parts-tabs', label: 'Notes'})
              +tab-content({class: 'p-3'})
                +dp-form({id: 'parts_form'})
                  +dp-fitem('Notes', {class: 'multiline', name: 'PROD_NOTES', id: '~', rows: 3, placeholder: 'Product notes...'})
            div.mt-2.text-xs.opacity-50
              | All fields:
              span#parts_field_count 0
              |  | getData keys:
              span#parts_data_keys -

        //- ---- Pre/Post Slots ----
        h3.font-semibold.mb-2 Pre/Post Icon Slots
        div.bg-base-100.rounded-lg.p-4.mb-6(style="max-width:450px")
          +dp-form({id: 'slots-demo'})
            +dp-fitem('Search', {class: 'searchbox', name: 'SEARCH', id: '~', pre: 'search', post: 'x', placeholder: 'Type to search...'})
            +dp-fitem('Email', {class: 'textbox', name: 'SL_EMAIL', id: '~', pre: 'mail', placeholder: 'you@example.com'})
            +dp-fitem('Website', {class: 'textbox', name: 'SL_URL', id: '~', pre: 'globe', placeholder: 'https://'})
            +dp-fitem('Part Code', {class: 'textbox', name: 'SL_CODE', id: '~', pre: 'hash', post: {action: true, icon: 'search', id: 'btn_lookup'}})

        //- ---- Groups ----
        h3.font-semibold.mb-2 Field Groups
        div.bg-base-100.rounded-lg.p-4(style="max-width:450px")
          +dp-form({id: 'group-demo'})
            +dp-fitem('Part ID', {class: 'combobox', name: 'GRP_PART', id: '~', pre: 'package', options: ['A8000', 'B3200']})
            +dp-fitem('Description', {class: 'textbox', name: 'GRP_DESC', id: '~'})
            +dp-group('Dimensions')
              +dp-fitem('Width', {class: 'numberbox', name: 'GRP_W', id: '~', precision: 2})
              +dp-fitem('Height', {class: 'numberbox', name: 'GRP_H', id: '~', precision: 2})
            +dp-hgroup('Rates')
              +dp-fitem('Base', {class: 'numberbox', name: 'GRP_BASE', id: '~', precision: 4})
              +dp-fitem('Tax %', {class: 'numberbox', name: 'GRP_TAX', id: '~', precision: 1})

        //- ---- Interactive JS for form demos ----
        script.
          document.addEventListener('DOMContentLoaded', () => {
            if (typeof dp === 'undefined') return;
            dp.on('ready', () => {
              // CRUD form with state machine
              const crudForm = dp.form('#crud_form');
              crudForm.bind('#crud_toolbar_toolbar', { idField: 'CRUD_PART' });
              crudForm.onModeChange((mode) => {
                document.getElementById('crud_mode_display').textContent = mode;
              });
              crudForm.onChange(() => {
                document.getElementById('crud_dirty_display').textContent = crudForm.isDirty();
              });

              // Form-parts demo
              const partsForm = dp.form('#parts_form');
              partsForm.bind('#parts_toolbar_toolbar', { idField: 'PROD_ID' });
              const updatePartsInfo = () => {
                document.getElementById('parts_field_count').textContent = partsForm.fields().length;
                document.getElementById('parts_data_keys').textContent = Object.keys(partsForm.getData()).join(', ');
              };
              updatePartsInfo();
              partsForm.onChange(updatePartsInfo);
            });
          });

      //- ===== TAB: Toolbar =====
      +tab({name: 'showcase', label: 'Toolbar'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        div.space-y-3.bg-base-100.rounded-lg.overflow-hidden
          +dp-toolbar({title: 'Parts List', icon: 'box', asdpx: 'aed'})
          +dp-toolbar({title: 'BOM Lines', icon: 'layers', asdpx: 'aed'})
            +dp-toolbar-sep
            +btn({size: 'xs', style: 'ghost'})
              +dp-icon('check-circle', {size: 'sm'})
              |  Validate
            +btn({size: 'xs', style: 'ghost'})
              +dp-icon('download', {size: 'sm'})
              |  Export
          +dp-toolbar({title: 'Order Entry', icon: 'shopping-cart', asdpx: 'asdx'})
          +dp-toolbar
            +btn({size: 'xs', style: 'ghost'})
              +dp-icon('refresh-cw', {size: 'sm'})
              |  Refresh
            +dp-toolbar-sep
            +btn({size: 'xs', style: 'ghost'})
              +dp-icon('file-down', {size: 'sm'})
              |  Export CSV

      //- ===== TAB: Tables =====
      +tab({name: 'showcase', label: 'Tables'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        h3.font-semibold.mb-2 Auto-width columns (default)
        div.bg-base-100.rounded-lg.p-4.mb-6
          +table({headers: ['Part ID', 'Description', 'Qty', 'Price', 'Status'], rows: [['A8000', 'Hydraulic Pump', '120', '$199.99', 'Active'], ['B3200', 'Bearing Kit', '45', '$12.00', 'Active'], ['C1500', 'Control Valve', '8', '$285.00', 'Draft']], zebra: true, size: 'sm'})

        h3.font-semibold.mb-2 DataTable with Pagination
        div.bg-base-100.rounded-lg.p-4
          +dp-datatable({headers: ['Date', 'Unit', 'Name', 'Type'], rows: [['Mar 22', 'B-05-08', 'Sensor A', 'knock-1'], ['Mar 22', 'B-05-08', 'Sensor A', 'knock-1'], ['Mar 21', 'C-04-10', 'Mobile', 'knock-2'], ['Mar 21', 'B-05-08', 'Sensor A', 'knock-1'], ['Mar 20', 'B-05-08', 'Sensor A', 'blunt']], zebra: true, size: 'sm', pagination: {current: 1, total: 3}})

      //- ===== TAB: Dock =====
      +tab({name: 'showcase', label: 'Dock'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        div.bg-base-100.rounded-lg.overflow-hidden(style="height:200px; position:relative")
          div.p-4 Content area above the dock
          div(style="position:absolute; bottom:0; left:0; right:0")
            +dock({size: 'sm', items: [{name: 'home', text: 'Home', active: true}, {name: 'search', text: 'Search'}, {name: 'profile', text: 'Profile'}, {name: 'settings', text: 'Settings'}]})

      //- ===== TAB: Tabs =====
      +tab({name: 'showcase', label: 'Tabs'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        h3.font-semibold.mb-2 Box style
        +tabs({style: 'box'})
          +tab({name: 'box-demo', label: 'Tab A', active: true})
          +tab-content({class: 'p-4'})
            p Box tab A content
          +tab({name: 'box-demo', label: 'Tab B'})
          +tab-content({class: 'p-4'})
            p Box tab B content

        h3.font-semibold.mt-6.mb-2 Lift style
        +tabs({style: 'lift'})
          +tab({name: 'lift-demo', label: 'First', active: true})
          +tab-content({class: 'bg-base-100 p-4 rounded-box'})
            p Lift tab content
          +tab({name: 'lift-demo', label: 'Second'})
          +tab-content({class: 'bg-base-100 p-4 rounded-box'})
            p Second tab

      //- ===== TAB: Modals =====
      +tab({name: 'showcase', label: 'Modals'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        div.flex.gap-3
          +btn({color: 'primary'})(onclick="demo_basic.showModal()")
            +dp-icon('message-square', {size: 'sm'})
            |  Basic Modal
          +btn({color: 'secondary'})(onclick="demo_form.showModal()")
            +dp-icon('file-edit', {size: 'sm'})
            |  Form Modal

        +modal({id: 'demo_basic'})
          +modal-box
            h3.text-lg.font-bold Hello!
            p.py-4 Press ESC or click outside to close.
            +modal-action
              form(method="dialog")
                +btn({text: 'Close'})

        +dp-modalform('demo_form', 'Edit Record', {color: 'primary'}, [{label: 'Name', name: 'modal_name'}, {label: 'Email', name: 'modal_email', type: 'email'}, {label: 'Role', as: 'select', name: 'modal_role', options: ['Admin', 'User', 'Guest']}], {submit: 'Save', cancel: 'Cancel'})

      //- ===== TAB: Buttons =====
      +tab({name: 'showcase', label: 'Buttons'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        h3.font-semibold.mb-2 With Icons
        div.flex.flex-wrap.gap-2.mb-4
          +btn({color: 'primary'})
            +dp-icon('plus', {size: 'sm'})
            |  Add New
          +btn({color: 'secondary'})
            +dp-icon('download', {size: 'sm'})
            |  Download
          +btn({color: 'accent'})
            +dp-icon('send', {size: 'sm'})
            |  Submit
          +btn({style: 'outline', color: 'error'})
            +dp-icon('trash-2', {size: 'sm'})
            |  Delete
          +btn({style: 'ghost'})
            +dp-icon('settings', {size: 'sm'})
            |  Settings

        h3.font-semibold.mb-2 Colors (no icons)
        div.flex.flex-wrap.gap-2.mb-4
          +btn({color: 'primary', text: 'Primary'})
          +btn({color: 'secondary', text: 'Secondary'})
          +btn({color: 'accent', text: 'Accent'})
          +btn({color: 'info', text: 'Info'})
          +btn({color: 'success', text: 'Success'})
          +btn({color: 'warning', text: 'Warning'})
          +btn({color: 'error', text: 'Error'})

        h3.font-semibold.mb-2 Styles
        div.flex.flex-wrap.gap-2.mb-4
          +btn({style: 'outline', color: 'primary', text: 'Outline'})
          +btn({style: 'soft', color: 'success', text: 'Soft'})
          +btn({style: 'dash', color: 'warning', text: 'Dash'})
          +btn({style: 'ghost', text: 'Ghost'})
          +btn({style: 'link', text: 'Link'})

        h3.font-semibold.mb-2 Badges
        div.flex.flex-wrap.gap-2
          +badge({color: 'primary', text: 'Primary'})
          +badge({color: 'secondary', style: 'outline', text: 'Outline'})
          +badge({color: 'accent', style: 'soft', text: 'Soft'})
          +badge({color: 'info', text: 'Info', size: 'lg'})
          +badge({color: 'success', style: 'dash', text: 'Dash'})

      //- ===== TAB: Chat =====
      +tab({name: 'showcase', label: 'Chat'})
      +tab-content({class: 'bg-base-200 p-4 overflow-auto'})

        div.bg-base-100.rounded-lg.p-4(style="max-width:500px")
          +dp-conversation([{from: 'Alice', text: 'Hey! Have you tried DaisyPug?', position: 'start', color: 'primary'}, {from: 'Bob', text: 'Yes! The mixins are incredibly clean.', position: 'end'}, {from: 'Alice', text: 'And it has a full JS API too!', position: 'start', color: 'primary'}, {from: 'Bob', text: 'The form system is like DUI but better.', position: 'end'}])

      //- ===== TAB: Full App =====
      +tab({name: 'showcase', label: 'Full App'})
      +tab-content({class: 'bg-base-200 overflow-hidden'})

        div.h-full
          +dp-vsplit('320px')
            +dp-panel('west')
              +dp-toolbar({title: 'Part', icon: 'search', asdpx: 'asdx'})
              div.p-3
                +dp-form({id: 'app-form'})
                  +dp-fitem('Part ID', {class: 'combobox', name: 'APP_PART', id: '~', pre: 'package', options: ['A8000 - Pump', 'B3200 - Bearing', 'C1500 - Valve']})
                  +dp-fitem('Description', {class: 'textbox', name: 'APP_DESC', id: '~'})
                  +dp-group('Dimensions')
                    +dp-fitem('Width', {class: 'numberbox', name: 'APP_W', id: '~', precision: 2})
                    +dp-fitem('Height', {class: 'numberbox', name: 'APP_H', id: '~', precision: 2})
                  +dp-group('Financials')
                    +dp-fitem('Cost', {class: 'numberbox', name: 'APP_COST', id: '~', precision: 2, pre: 'dollar-sign'})
                    +dp-fitem('Currency', {class: 'combobox', name: 'APP_CUR', id: '~', options: ['SGD', 'USD']})
                  +dp-fitem('Active', {class: 'checkbox', name: 'APP_ACTIVE', id: '~', checked: true})
            +dp-panel('center')
              +dp-toolbar({title: 'Stock Balances', icon: 'warehouse', asdpx: 'aed'})
              div.p-2
                +table({headers: ['Location', 'On Hand', 'Reserved', 'Available'], rows: [['Main Store', '120', '15', '105'], ['Sub Store', '45', '0', '45'], ['Yard', '8', '2', '6']], zebra: true, size: 'sm'})
